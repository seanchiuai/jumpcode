#!/usr/bin/env bash
set -euo pipefail

# Nesting-safety: start-webapp may be launched from inside another tmux session
# (e.g. a Ghostty shell auto-wrapped on the 'wt' socket by ~/.zshrc). Detach from
# it so every tmux command here targets the DEFAULT server where jumpcode
# workspaces live, and so `new-session` is not refused by tmux's nest guard
# ("sessions should be nested with care"). tmux re-sets $TMUX inside each pane it
# creates, so intra-jumpcode dispatch auto-resolution (which reads $TMUX) is
# unaffected. start-webapp itself never reads $TMUX.
unset TMUX

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "/Users/seanchiu/Desktop/workspace-macbook" ]]; then
  DEFAULT_ROOT="/Users/seanchiu/Desktop/workspace-macbook"
else
  DEFAULT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
fi
ROOT="${JUMPCODE_ROOT:-$DEFAULT_ROOT}"
if [[ -z "${JUMPCODE_HOME:-}" ]]; then
  if [[ -x "$SCRIPT_DIR/jumpcode" && "$SCRIPT_DIR" == "$ROOT/bin" ]]; then
    JUMPCODE_HOME="$ROOT"          # source checkout layout
  else
    JUMPCODE_HOME="$ROOT/.jumpcode"  # installed workspace layout
  fi
fi
JUMPCODE_BIN="$JUMPCODE_HOME/bin"
# Per-workspace session so multiple workspaces run side by side instead of evicting each
# other. Default workspace 'webapp' keeps its historical name 'macbook-webapp'.
SESSION="${JUMPCODE_TMUX_SESSION:-macbook-${JUMPCODE_WORKSPACE:-webapp}}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
CODEX_BIN="${CODEX_BIN:-/Applications/Codex.app/Contents/Resources/codex}"
# Per-runtime launch flags appended after the program. Codex defaults to --yolo
# (no approval prompts) so visible panes run unattended; override with CODEX_ARGS=''.
CLAUDE_ARGS="${CLAUDE_ARGS:-}"
CODEX_ARGS="${CODEX_ARGS:---yolo}"
KILL_EXISTING="${JUMPCODE_KILL_EXISTING:-1}"
# Resume mode (opt-in; bare start-webapp stays fresh per ADR 0004). When set, every claude
# role reuses its recorded session id from the prior launch manifest and is launched on the
# RESUME path instead of being assigned a brand-new id. Roles with no recorded id (a role
# added since the last launch, codex, or a never-recorded workspace) fall back to fresh.
# The `revive` bin is the user-facing verb that turns this on.
RESUME_MODE="${JUMPCODE_RESUME:-0}"
RESUME_FLAG=""; [[ "$RESUME_MODE" == "1" ]] && RESUME_FLAG="resume"

# Runtime registry (inline, data-shaped — borrow Claude Squad's "profile" idea without a
# new config file). Maps a runtime name to the program that fills a pane. Add a third
# runtime here when one actually arrives.
runtime_program() {
  case "$1" in
    claude) printf '%s' "$CLAUDE_BIN" ;;
    codex)  printf '%s' "$CODEX_BIN" ;;
    *)      printf '' ;;   # unknown runtime
  esac
}

# Extra CLI flags per runtime (e.g. codex --yolo for unattended panes).
runtime_args() {
  case "$1" in
    claude) printf '%s' "$CLAUDE_ARGS" ;;
    codex)  printf '%s' "$CODEX_ARGS" ;;
    *)      printf '' ;;
  esac
}

cd "$ROOT"

agent_cmd() {
  local role="$1"
  local prompt_file="$2"
  local runtime="${3:-claude}"
  local sid="${4:-}"        # claude session id to pin (recorded in the launch manifest)
  local resume="${5:-}"     # non-empty => resume the sid instead of starting it (respawn path)
  local program
  program="$(runtime_program "$runtime")"
  [[ -z "$program" ]] && program="$CLAUDE_BIN"   # safety net; preflight already validated
  local rt_args
  rt_args="$(runtime_args "$runtime")"
  # For claude, pin the session id so every launched role is recorded and deterministically
  # resumable (no reverse-engineering from transcripts). A fresh launch assigns the id with
  # --session-id; the reconcile/respawn pass reconnects to it with --resume.
  # Build the final launch line. Fresh claude launches pin a new id with --session-id. A
  # respawn RESUMES the recorded id, but falls back to creating it fresh under the same id
  # if that session was never persisted — a straggler that died before its first write makes
  # `claude --resume` exit 1 ("No conversation found"), and `--session-id` on an id that DID
  # persist exits 1 ("already in use"), so neither flag alone is safe on the respawn path.
  local launch="exec \"$program\" $rt_args"
  if [[ "$runtime" == "claude" && -n "$sid" ]]; then
    if [[ -n "$resume" ]]; then
      launch="\"$program\" $rt_args --resume $sid || exec \"$program\" $rt_args --session-id $sid"
    else
      launch="exec \"$program\" $rt_args --session-id $sid"
    fi
  fi
  cat <<EOF
cd "$WORKSPACE_ROOT"
export JUMPCODE_TMUX_SESSION="$SESSION"
export JUMPCODE_HOME="$JUMPCODE_HOME"
printf '\\033]2;%s\\033\\\\' "$role"
clear
printf 'MacBook webapp jumpcode role: %s (%s)\\n' "$role" "$runtime"
printf 'Prompt file: %s\\n\\n' "$prompt_file"
printf '%s will start now. Initial instructions will be injected by tmux.\\n' "$runtime"
$launch
EOF
}

feed_cmd="cd '$ROOT'; export JUMPCODE_HOME='$JUMPCODE_HOME'; printf '\\033]2;feed\\033\\\\'; touch \"\$JUMPCODE_HOME/shared/conversation.log\"; clear; echo 'conversation feed (press Ctrl-b n/p to switch windows)'; tail -n 120 -f \"\$JUMPCODE_HOME/shared/conversation.log\""
status_cmd="cd '$ROOT'; export JUMPCODE_HOME='$JUMPCODE_HOME'; printf '\\033]2;status\\033\\\\'; while true; do clear; echo 'jumpcode status (updates every 5s)'; date; \"\$JUMPCODE_HOME/bin/status\" || true; sleep 5; done"

# The ONLY fixed rule: the orchestrator owns the full-height RIGHT column. Team leads
# are discovered by the centralized jumpcode role-discovery command from central prompts
# plus repo-local overlays. No team roster JSON needs to be kept in sync.
WORKSPACE="${JUMPCODE_WORKSPACE:-webapp}"
DRY_RUN="${JUMPCODE_DRY_RUN:-0}"
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    *) echo "unknown argument: $arg" >&2; exit 2 ;;
  esac
done

DISCOVERY_JSON="$(JUMPCODE_HOME="$JUMPCODE_HOME" "$JUMPCODE_BIN/jumpcode" roles discover --workspace "$WORKSPACE" --json)"
if [[ "$DRY_RUN" == "1" ]]; then
  printf '%s\n' "$DISCOVERY_JSON"
  exit 0
fi

# Extract the authoritative launch data from discovery JSON. Each role line is:
# role <TAB> prompt_file <TAB> display_name <TAB> runtime <TAB> kind
WORKSPACE_ROOT="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["workspace_root"])' <<<"$DISCOVERY_JSON")"
SHARED_PROTOCOL="$(python3 -c 'import json,sys; print(json.load(sys.stdin)["protocol"])' <<<"$DISCOVERY_JSON")"
# Human-facing task title for the orchestrator's column (workspace.json "title"; falls back
# to the workspace name). Shown on the orchestrator pane border instead of a generic label.
WORKSPACE_TITLE="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("title") or d["workspace"])' <<<"$DISCOVERY_JSON")"
ORCH_LABEL="🧭 $WORKSPACE_TITLE"   # orchestrator border, used on both the normal and respawn paths

ORCH_PROMPT=""
ORCH_NAME="orchestrator"
ORCH_RUNTIME="claude"
LEAD_ROLES=(); LEAD_PROMPTS=(); LEAD_NAMES=(); LEAD_RUNTIMES=()
while IFS=$'\t' read -r role pf name runtime kind; do
  [[ -z "$role" ]] && continue
  if [[ "$kind" == "orchestrator" ]]; then
    ORCH_PROMPT="$pf"; ORCH_NAME="$name"; ORCH_RUNTIME="$runtime"
  else
    LEAD_ROLES+=("$role"); LEAD_PROMPTS+=("$pf"); LEAD_NAMES+=("$name"); LEAD_RUNTIMES+=("$runtime")
  fi
done < <(python3 -c 'import json,sys
for r in json.load(sys.stdin)["roles"]:
    print("%s\t%s\t%s\t%s\t%s" % (r["id"], r["prompt"], r["display"], r["runtime"], r["kind"]))' <<<"$DISCOVERY_JSON")

if [[ -z "$ORCH_PROMPT" ]]; then
  echo "role discovery did not return an orchestrator" >&2
  exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required" >&2
  exit 1
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
  if [[ "$KILL_EXISTING" == "1" ]]; then
    tmux kill-session -t "$SESSION"
  else
    echo "session already exists: $SESSION" >&2
    exit 2
  fi
fi

# Validate the program for every runtime this workspace uses, before creating any pane.
# (Replaces the old single Claude-only check; supports mixed claude/codex teams.)
declare -A _RT_SEEN=()
for rt in "$ORCH_RUNTIME" "${LEAD_RUNTIMES[@]:-}"; do
  [[ -z "$rt" || -n "${_RT_SEEN[$rt]:-}" ]] && continue
  _RT_SEEN[$rt]=1
  prog="$(runtime_program "$rt")"
  if [[ -z "$prog" ]]; then
    echo "unknown runtime '$rt' in role_runtimes — use 'claude' or 'codex'" >&2
    exit 1
  fi
  if ! command -v "$prog" >/dev/null 2>&1 && [[ ! -x "$prog" ]]; then
    echo "runtime '$rt' program not found/executable: $prog" >&2
    echo "  (for codex, set CODEX_BIN or reinstall; default is the app-bundled binary)" >&2
    exit 1
  fi
done

# Pre-assign a claude session id per role (orchestrator + each lead) so every launched
# pane is recorded in a manifest and can be resumed deterministically. codex roles get no
# id (different session model). Generated up front so the same id is used at launch and on
# any reconcile/respawn below.
gen_sid() { uuidgen | tr 'A-Z' 'a-z'; }
# Resume mode: load the prior launch manifest into a role->sid map so each role reuses its
# own recorded session id. Role discovery (above) stays the source of truth for WHO runs;
# the manifest only supplies the id for WHOM — a role added/removed since last launch is
# handled by discovery, and a role with no recorded id just gets a fresh one below.
declare -A RECORDED_SID=()
PRIOR_MANIFEST="$JUMPCODE_HOME/state/sessions/$WORKSPACE.json"
if [[ "$RESUME_MODE" == "1" && -f "$PRIOR_MANIFEST" ]]; then
  while IFS=$'\t' read -r _role _sid; do
    [[ -n "$_role" && -n "$_sid" ]] && RECORDED_SID["$_role"]="$_sid"
  done < <(python3 -c 'import json,sys
for r in json.load(open(sys.argv[1])).get("roles",[]):
    if r.get("session_id"): print("%s\t%s" % (r["role"], r["session_id"]))' "$PRIOR_MANIFEST")
  echo "resume mode: ${#RECORDED_SID[@]} recorded session id(s) loaded from $PRIOR_MANIFEST" >&2
elif [[ "$RESUME_MODE" == "1" ]]; then
  echo "resume mode: no prior manifest at $PRIOR_MANIFEST — launching fresh" >&2
fi
# Pick a session id for a role: its recorded id in resume mode, else a fresh one.
pick_sid() {  # role
  if [[ "$RESUME_MODE" == "1" && -n "${RECORDED_SID[$1]:-}" ]]; then printf '%s' "${RECORDED_SID[$1]}"; else gen_sid; fi
}
ORCH_SID=""
[[ "$ORCH_RUNTIME" == "claude" ]] && ORCH_SID="$(pick_sid orchestrator)"
LEAD_SIDS=()
for (( i=0; i<${#LEAD_ROLES[@]}; i++ )); do
  if [[ "${LEAD_RUNTIMES[$i]}" == "claude" ]]; then LEAD_SIDS[$i]="$(pick_sid "${LEAD_ROLES[$i]}")"; else LEAD_SIDS[$i]=""; fi
done

# Orchestrator pane: the fixed right column.
# Create at a generous virtual size so a tall left column of leads has room to split;
# tmux resizes to the client when one attaches. (A tiny default size makes split-window
# fail once there are several leads.)
ORCH=$(tmux new-session -d -P -F '#{pane_id}' -x "${JUMPCODE_COLS:-260}" -y "${JUMPCODE_ROWS:-72}" -s "$SESSION" -n roles -c "$WORKSPACE_ROOT" "$(agent_cmd orchestrator "$ORCH_PROMPT" "$ORCH_RUNTIME" "$ORCH_SID" "$RESUME_FLAG")")

# Keep panes that exit during the startup window REVIVABLE rather than letting tmux drop
# them (a dropped pane collapses the grid and loses a role). codex's TUI occasionally
# exits cleanly right after launch (an init race); the reconcile pass below respawns any
# such straggler. Turned back off once the grid has settled.
tmux set-option -w -t "$SESSION:roles" remain-on-exit on >/dev/null 2>&1 || true

# Lead panes laid out in COLUMNS of at most MAX_PER_COL, to the LEFT of the orchestrator.
# No column holds more than MAX_PER_COL panes; with more leads we add another column
# instead of a taller stack. Order is left->right then top->bottom, in workspace order.
# Only the orchestrator's right-column ownership is fixed; lead positions are incidental.
MAX_PER_COL="${JUMPCODE_MAX_PER_COL:-3}"
N=${#LEAD_ROLES[@]}
LEAD_PANE=()        # LEAD_PANE[i] = pane id for lead i (parallel to LEAD_ROLES)
COL_HEADS=()        # head (top) pane of each lead column
NCOLS=0
if (( N > 0 )); then NCOLS=$(( (N + MAX_PER_COL - 1) / MAX_PER_COL )); fi

# 1) Column heads: each split is inserted just left of the orchestrator, so columns end
#    up ordered [col0][col1]...[orchestrator] left-to-right.
for (( c=0; c<NCOLS; c++ )); do
  idx=$(( c * MAX_PER_COL ))
  head=$(tmux split-window -P -F '#{pane_id}' -t "$ORCH" -h -b -c "$WORKSPACE_ROOT" \
           "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}" "${LEAD_RUNTIMES[$idx]}" "${LEAD_SIDS[$idx]:-}" "$RESUME_FLAG")") \
    || { echo "warn: no room for lead column $c — raise JUMPCODE_COLS" >&2; continue; }
  LEAD_PANE[$idx]=$head
  COL_HEADS[$c]=$head
done

# 2) Stack the remaining leads (rows 1..MAX-1) under each column head.
for (( c=0; c<NCOLS; c++ )); do
  prev="${COL_HEADS[$c]:-}"
  [[ -z "$prev" ]] && continue
  for (( r=1; r<MAX_PER_COL; r++ )); do
    idx=$(( c * MAX_PER_COL + r ))
    if (( idx >= N )); then break; fi
    pane=$(tmux split-window -P -F '#{pane_id}' -t "$prev" -v -c "$WORKSPACE_ROOT" \
             "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}" "${LEAD_RUNTIMES[$idx]}" "${LEAD_SIDS[$idx]:-}" "$RESUME_FLAG")") \
      || { echo "warn: no room for lead '${LEAD_ROLES[$idx]}' — raise JUMPCODE_ROWS" >&2; continue; }
    LEAD_PANE[$idx]=$pane
    prev=$pane
  done
done

# 3) Label every lead pane. @role is visible; @jumpcode_role is the wake-target machine id.
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -z "$p" ]] && continue
  tmux select-pane -t "$p" -T "${LEAD_NAMES[$i]}"
  tmux set-option -pt "$p" @role "${LEAD_NAMES[$i]}"
  tmux set-option -pt "$p" @jumpcode_role "${LEAD_ROLES[$i]}"
  tmux set-option -pt "$p" @jumpcode_runtime "${LEAD_RUNTIMES[$i]}"
done

# Orchestrator labels. The border shows the workspace's TASK (workspace.json "title"), not a
# generic "owns this column" — the orchestrator still owns the right column by position.
tmux select-pane -t "$ORCH" -T "$ORCH_LABEL"
tmux set-option -pt "$ORCH" @role "$ORCH_LABEL"
tmux set-option -pt "$ORCH" @jumpcode_role "orchestrator"
tmux set-option -pt "$ORCH" @jumpcode_runtime "$ORCH_RUNTIME"

# The orchestrator owns the RIGHT HALF of the screen; all lead columns share the LEFT
# half, split evenly among them. So each lead column is (WINDOW_WIDTH/2)/NCOLS wide and
# the orchestrator keeps the remaining ~half, no matter how many lead columns there are.
# Then even the rows within each column.
WINDOW_WIDTH=$(tmux display-message -p -t "$SESSION:roles" '#{window_width}' 2>/dev/null || echo 200)
WIN_H=$(tmux display-message -p -t "$SESSION:roles" '#{window_height}' 2>/dev/null || echo 50)
if (( NCOLS > 0 )); then
  col_w=$(( WINDOW_WIDTH / 2 / NCOLS ))
  (( col_w < 1 )) && col_w=1
  for (( c=0; c<NCOLS; c++ )); do
    [[ -n "${COL_HEADS[$c]:-}" ]] && tmux resize-pane -t "${COL_HEADS[$c]}" -x "$col_w" >/dev/null 2>&1 || true
    rows=$(( N - c * MAX_PER_COL )); if (( rows > MAX_PER_COL )); then rows=$MAX_PER_COL; fi
    if (( rows > 1 )); then
      per=$(( WIN_H / rows ))
      for (( r=0; r<rows; r++ )); do
        p="${LEAD_PANE[$(( c * MAX_PER_COL + r ))]:-}"
        [[ -n "$p" ]] && tmux resize-pane -t "$p" -y "$per" >/dev/null 2>&1 || true
      done
    fi
  done
fi

tmux set-option -w -t "$SESSION:roles" pane-border-status top >/dev/null
tmux set-option -w -t "$SESSION:roles" pane-border-format ' #[bold,fg=cyan]#{@role} #[default]' >/dev/null

# Monitor window: logs/status are available but do not steal space from role panes.
# Best-effort: the monitor is non-essential, so a failed split or a status pane that
# exits before we can label it must NEVER abort the launch (set -e). Previously an
# unguarded `select-pane monitor.1` on a vanished status pane raised "can't find pane: 1"
# and killed the whole launch before send_initial / reconcile / the iTerm window opened.
tmux new-window -d -t "$SESSION" -n monitor -c "$ROOT" "$feed_cmd" 2>/dev/null || true
tmux split-window -t "$SESSION:monitor" -h -c "$ROOT" "$status_cmd" 2>/dev/null || true
tmux select-layout -t "$SESSION:monitor" even-horizontal >/dev/null 2>&1 || true
tmux select-pane -t "$SESSION:monitor.0" -T feed 2>/dev/null || true
tmux select-pane -t "$SESSION:monitor.1" -T status 2>/dev/null || true

# Default the user-facing window to the clean role grid.
tmux select-window -t "$SESSION:roles"
tmux select-pane -t "$ORCH"

sleep "${JUMPCODE_CLAUDE_START_DELAY:-6}"
send_initial() {
  local pane_id="$1"
  local role="$2"
  local prompt_file="$3"
  local extra="${4:-}"
  # Send the prompt text and the Enter as SEPARATE send-keys calls. A combined
  # `send-keys "...text..." Enter` is unreliable right after Claude's TUI starts — the
  # Enter can land before the input is ready and the prompt sits unsubmitted. Two calls
  # (with a beat between) is what makes wake_pane reliable; mirror it here.
  tmux send-keys -t "$pane_id" -- "You are the $WORKSPACE workspace $role. You are running from repo/workspace root $WORKSPACE_ROOT. Read your charter $prompt_file and the shared protocol $SHARED_PROTOCOL. Projects and tasks live in GitHub issues — use the gh CLI as the system of record; there is no local task registry. Check your inbox now: $JUMPCODE_BIN/dispatch inbox $role. Then wait — when someone dispatches you, this pane is woken automatically. Send messages with $JUMPCODE_BIN/dispatch send --from $role --to <role> [--task #NN] BODY.${extra:+ }$extra"
  sleep 0.4
  tmux send-keys -t "$pane_id" Enter
}

# Authoritative roster for the orchestrator: the exact leads THIS launch created, so it
# never falls back to a stale hardcoded list in its charter. Includes each lead's runtime.
ORCH_ROSTER=""
for (( i=0; i<N; i++ )); do
  [[ -z "${LEAD_PANE[$i]:-}" ]] && continue
  ORCH_ROSTER+="${ORCH_ROSTER:+, }${LEAD_ROLES[$i]} (${LEAD_RUNTIMES[$i]})"
done
ORCH_EXTRA="YOUR TEAM LEADS in this workspace are exactly these ${N} and they are ALL yours: ${ORCH_ROSTER}. Treat every one of them as your own lead — do not disown any as belonging to another workspace. Confirm the live roster any time with ./.jumpcode/bin/health (every *-lead pane is yours)."

send_initial "$ORCH" orchestrator "$ORCH_PROMPT" "$ORCH_EXTRA"
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -n "$p" ]] && send_initial "$p" "${LEAD_ROLES[$i]}" "${LEAD_PROMPTS[$i]}"
done

# Reconcile stragglers: respawn any role pane whose runtime exited during startup, then
# re-send its initial prompt, so the grid always comes up complete. Up to two rounds.
RESP_PANES=(); RESP_ROLES=(); RESP_PF=(); RESP_EXTRA=()
respawn_if_dead() {   # pane role prompt runtime display extra sid
  local pane="$1" role="$2" pf="$3" rt="$4" disp="$5" extra="${6:-}" sid="${7:-}"
  [[ -z "$pane" ]] && return 0
  [[ "$(tmux display-message -p -t "$pane" '#{pane_dead}' 2>/dev/null || echo 1)" != "1" ]] && return 0
  # resume the pane's recorded session id (5th agent_cmd arg) so a straggler keeps its thread
  tmux respawn-pane -k -t "$pane" -c "$WORKSPACE_ROOT" "$(agent_cmd "$role" "$pf" "$rt" "$sid" resume)" 2>/dev/null || return 0
  tmux select-pane -t "$pane" -T "$disp" 2>/dev/null || true
  tmux set-option -pt "$pane" @role "$disp" 2>/dev/null || true
  tmux set-option -pt "$pane" @jumpcode_role "$role" 2>/dev/null || true
  tmux set-option -pt "$pane" @jumpcode_runtime "$rt" 2>/dev/null || true
  RESP_PANES+=("$pane"); RESP_ROLES+=("$role"); RESP_PF+=("$pf"); RESP_EXTRA+=("$extra")
}
for round in 1 2; do
  RESP_PANES=(); RESP_ROLES=(); RESP_PF=(); RESP_EXTRA=()
  respawn_if_dead "$ORCH" orchestrator "$ORCH_PROMPT" "$ORCH_RUNTIME" "$ORCH_LABEL" "$ORCH_EXTRA" "$ORCH_SID"
  for (( i=0; i<N; i++ )); do
    respawn_if_dead "${LEAD_PANE[$i]:-}" "${LEAD_ROLES[$i]}" "${LEAD_PROMPTS[$i]}" "${LEAD_RUNTIMES[$i]}" "${LEAD_NAMES[$i]}" "" "${LEAD_SIDS[$i]:-}"
  done
  (( ${#RESP_PANES[@]} == 0 )) && break
  echo "reconcile round $round: respawned ${#RESP_PANES[@]} straggler pane(s)" >&2
  sleep "${JUMPCODE_RESPAWN_DELAY:-6}"
  for (( j=0; j<${#RESP_PANES[@]}; j++ )); do
    send_initial "${RESP_PANES[$j]}" "${RESP_ROLES[$j]}" "${RESP_PF[$j]}" "${RESP_EXTRA[$j]}"
  done
done
# Grid settled: restore normal exit behavior so a later crash is visible to health, not retained forever.
tmux set-option -w -t "$SESSION:roles" remain-on-exit off >/dev/null 2>&1 || true

# Poisoned-server guard: if every role pane died on startup, the agent runtime couldn't
# start in this tmux server. The classic cause is an EPERM — the default tmux server was
# first spawned inside a sandboxed/agent context days ago, so it's seatbelted and a new
# claude can't sandbox-init (nested sandbox). Don't leave a silent grid of dead panes;
# surface the diagnosis and the one fix that works (recreate the server from a clean shell).
_dead=0; _total=0
while IFS= read -r _d; do _total=$((_total+1)); [[ "$_d" == "1" ]] && _dead=$((_dead+1)); done \
  < <(tmux list-panes -t "$SESSION:roles" -F '#{pane_dead}' 2>/dev/null)
if (( _total > 0 && _dead == _total )); then
  _sample="$(tmux capture-pane -p -t "$SESSION:roles" 2>/dev/null | grep -m1 -i 'EPERM\|error' || true)"
  {
    echo ""
    echo "  ┌─ JUMPCODE LAUNCH FAILED ──────────────────────────────────────────────"
    echo "  │ All $_total role panes died on startup. The runtime can't start in this"
    echo "  │ tmux server. Sample: ${_sample:-<no output captured>}"
    if printf '%s' "$_sample" | grep -qi 'EPERM'; then
      echo "  │"
      echo "  │ EPERM = this tmux server is seatbelted (it was first created from a"
      echo "  │ sandboxed/agent context). New claude processes can't sandbox-init."
      echo "  │ FIX — recreate the server from a clean terminal (NOT from an agent):"
      echo "  │     tmux kill-server      # all sessions resume from saved state"
      echo "  │     PATH=\"/opt/homebrew/bin:\$PATH\" $JUMPCODE_HOME/bin/revive $WORKSPACE"
    fi
    echo "  └───────────────────────────────────────────────────────────────────────"
    echo ""
  } >&2
fi

# Record every launched role's claude session id to a durable manifest so the team can be
# resumed deterministically after a relogin/crash without reverse-engineering transcripts.
# One file per workspace, overwritten each launch: $JUMPCODE_HOME/state/sessions/<workspace>.json
SESSION_DIR="$JUMPCODE_HOME/state/sessions"
mkdir -p "$SESSION_DIR" 2>/dev/null || true   # never abort the launch on a recording-dir hiccup (set -e)
{
  printf '%s\t%s\t%s\t%s\n' "orchestrator" "$ORCH" "$ORCH_RUNTIME" "$ORCH_SID"
  for (( i=0; i<N; i++ )); do
    printf '%s\t%s\t%s\t%s\n' "${LEAD_ROLES[$i]}" "${LEAD_PANE[$i]:-}" "${LEAD_RUNTIMES[$i]}" "${LEAD_SIDS[$i]:-}"
  done
} | WS="$WORKSPACE" SESS="$SESSION" WROOT="$WORKSPACE_ROOT" RECBY="$([[ "$RESUME_MODE" == "1" ]] && echo start-webapp-resume || echo start-webapp)" python3 -c '
import json, sys, os
roles = []
for line in sys.stdin:
    p = line.rstrip("\n").split("\t")
    if len(p) < 4 or not p[0]:
        continue
    role, pane, rt, sid = p[:4]
    # a pane that never spawned (the "no room" path) has no live session, so record null
    # rather than a uuid that was assigned but never passed to `claude --session-id`.
    roles.append({"role": role, "pane": pane, "runtime": rt, "session_id": (sid or None) if pane else None})
out = {"workspace": os.environ["WS"], "session": os.environ["SESS"],
       "workspace_root": os.environ["WROOT"], "recorded_by": os.environ.get("RECBY", "start-webapp"),
       "roles": sorted(roles, key=lambda r: r["role"])}
print(json.dumps(out, indent=2))
' > "$SESSION_DIR/$WORKSPACE.json" && echo "recorded session ids -> $SESSION_DIR/$WORKSPACE.json" >&2 || echo "warn: could not record session ids (grid is up regardless)" >&2

# Open visible iTerm window if available. If Automation permissions block this, tmux still runs.
if [[ "${JUMPCODE_OPEN_ITERM:-1}" == "1" ]]; then
  osascript >/dev/null 2>&1 <<OSA || true
tell application "iTerm2"
  activate
  create window with default profile
  tell current session of current window
    write text "cd '$ROOT' && tmux attach -t '$SESSION'"
  end tell
end tell
OSA
fi

echo "started tmux session: $SESSION"
echo "main roles: cd $ROOT && tmux attach -t $SESSION:roles"
echo "monitor logs: Ctrl-b n, or tmux switch-client -t $SESSION:monitor"
printf '\nRoles panes:\n'
tmux list-panes -t "$SESSION:roles" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
printf '\nMonitor panes:\n'
tmux list-panes -t "$SESSION:monitor" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
