#!/usr/bin/env bash
set -euo pipefail

ROOT="/Users/seanchiu/Desktop/workspace-macbook"
COCKPIT_HOME="$ROOT/.agent-cockpit"
COCKPIT_BIN="$COCKPIT_HOME/bin"
SESSION="${COCKPIT_TMUX_SESSION:-macbook-webapp}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
CODEX_BIN="${CODEX_BIN:-/Applications/Codex.app/Contents/Resources/codex}"
KILL_EXISTING="${COCKPIT_KILL_EXISTING:-1}"

# Runtime registry (inline, data-shaped — borrow Claude Squad's "profile" idea without a
# new config file). Maps a runtime name to the program that fills a pane. Add a third
# runtime here when one actually arrives.
runtime_program() {
  case "$1" in
    claude) printf '%s' "$CLAUDE_BIN" ;;
    codex)  printf '%s' "$CODEX_BIN" ;;
    *)      printf '' ;;   # unknown runtime
  esac
}

cd "$ROOT"

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required" >&2
  exit 1
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
  if [[ "$KILL_EXISTING" == "1" ]]; then
    tmux kill-session -t "$SESSION"
  else
    echo "session already exists: $SESSION" >&2
    exit 2
  fi
fi

agent_cmd() {
  local role="$1"
  local prompt_file="$2"
  local runtime="${3:-claude}"
  local program
  program="$(runtime_program "$runtime")"
  [[ -z "$program" ]] && program="$CLAUDE_BIN"   # safety net; preflight already validated
  cat <<EOF
cd "$WORKSPACE_ROOT"
export COCKPIT_TMUX_SESSION="$SESSION"
export COCKPIT_HOME="$COCKPIT_HOME"
printf '\\033]2;%s\\033\\\\' "$role"
clear
printf 'MacBook webapp cockpit role: %s (%s)\\n' "$role" "$runtime"
printf 'Prompt file: %s\\n\\n' "$prompt_file"
printf '%s will start now. Initial instructions will be injected by tmux.\\n' "$runtime"
exec "$program"
EOF
}

feed_cmd='cd /Users/seanchiu/Desktop/workspace-macbook; export COCKPIT_HOME="/Users/seanchiu/Desktop/workspace-macbook/.agent-cockpit"; printf "\\033]2;feed\\033\\\\"; touch "$COCKPIT_HOME/shared/conversation.log"; clear; echo "conversation feed (press Ctrl-b n/p to switch windows)"; tail -n 120 -f "$COCKPIT_HOME/shared/conversation.log"'
status_cmd='cd /Users/seanchiu/Desktop/workspace-macbook; export COCKPIT_HOME="/Users/seanchiu/Desktop/workspace-macbook/.agent-cockpit"; printf "\\033]2;status\\033\\\\"; while true; do clear; echo "cockpit status (updates every 5s)"; date; "$COCKPIT_HOME/bin/status" || true; sleep 5; done'

# The ONLY fixed rule: the orchestrator owns the full-height RIGHT column. Team leads
# are discovered from the workspace prompt folder: add/remove a role prompt file and
# relaunch. No team roster JSON needs to be kept in sync.
WORKSPACE="${COCKPIT_WORKSPACE:-webapp}"
WS_JSON=".agent-cockpit/workspaces/$WORKSPACE/workspace.json"

WORKSPACE_ROOT=$(python3 - "$WS_JSON" "$ROOT" "$WORKSPACE" <<'PY'
import json, sys
from pathlib import Path
ws_path = Path(sys.argv[1])
root = Path(sys.argv[2])
workspace = sys.argv[3]
ws = json.load(ws_path.open()) if ws_path.exists() else {}
value = ws.get("workspace_root", str(root / "workspaces" / workspace))
p = Path(value).expanduser()
if not p.is_absolute():
    p = root / p
print(p)
PY
)

resolve_workspace_path() {
  python3 - "$WS_JSON" "$ROOT" "$WORKSPACE_ROOT" "$1" <<'PY'
import sys
from pathlib import Path
_, ws_json, root_s, workspace_root_s, value = sys.argv
root = Path(root_s)
workspace_root = Path(workspace_root_s)
p = Path(value).expanduser()
if p.is_absolute():
    print(p)
    raise SystemExit
# Prefer repo-local paths so prompts can live with the code. Fall back to cockpit-root
# paths for central/shared prompts and legacy workspaces.
repo_candidate = workspace_root / p
root_candidate = root / p
print(repo_candidate if repo_candidate.exists() else root_candidate)
PY
}

# Dedicated prompt folder: repo-local wins, central cockpit roles are fallback.
if [[ -d "$WORKSPACE_ROOT/.agent-cockpit/roles" ]]; then
  PROMPT_DIR="$WORKSPACE_ROOT/.agent-cockpit/roles"
else
  PROMPT_DIR="$COCKPIT_HOME/roles"
fi

find_prompt_for_role() {
  python3 - "$PROMPT_DIR" "$1" <<'PY'
import re, sys
from pathlib import Path
prompt_dir = Path(sys.argv[1])
wanted = sys.argv[2]

def role_id_from_stem(stem: str) -> str:
    parts = stem.split(maxsplit=1)
    if len(parts) == 2 and re.search(r"[A-Za-z0-9]", parts[1]) and not re.match(r"[A-Za-z0-9]", parts[0]):
        return parts[1]
    return stem

for path in sorted(prompt_dir.glob("*.md"), key=lambda p: role_id_from_stem(p.stem)):
    if path.stem.startswith("_"):
        continue
    if role_id_from_stem(path.stem) == wanted:
        print(path)
        raise SystemExit
# conventional fallback for a just-created role with default filename
print(prompt_dir / f"{wanted}.md")
PY
}

ORCH_PROMPT="$(find_prompt_for_role orchestrator)"
SHARED_PROTOCOL="$PROMPT_DIR/_PROTOCOL.md"
# Team discovery is prompt-folder-driven. Display name comes from the filename stem,
# e.g. "🎨 frontend-lead.md" -> visible "🎨 frontend-lead" and dispatch id
# "frontend-lead". If no emoji/name prefix exists, stem is both name and id.
ORCH_NAME=$(python3 - "$ORCH_PROMPT" <<'PY'
import sys
from pathlib import Path
stem = Path(sys.argv[1]).stem
print(stem)
PY
)
ORCH_RUNTIME="claude"

# Build the lead list from prompt files in canonical role-id sort order, excluding
# orchestrator/_PROTOCOL and other private underscore files.
# Each line is: role <TAB> prompt_file <TAB> display_name <TAB> runtime
LEAD_ROLES=(); LEAD_PROMPTS=(); LEAD_NAMES=(); LEAD_RUNTIMES=()
while IFS=$'	' read -r role pf name runtime; do
  [[ -z "$role" ]] && continue
  LEAD_ROLES+=("$role"); LEAD_PROMPTS+=("$pf"); LEAD_NAMES+=("$name")
  LEAD_RUNTIMES+=("${runtime:-claude}")
done < <(python3 - "$PROMPT_DIR" "$WS_JSON" <<'PY'
import json, re, sys
from pathlib import Path
prompt_dir = Path(sys.argv[1])
ws_path = Path(sys.argv[2])
ws = json.load(ws_path.open()) if ws_path.exists() else {}

def role_id_from_stem(stem: str) -> str:
    # Allows filenames like "🎨 frontend-lead.md" while keeping dispatch target
    # "frontend-lead". For "frontend-lead.md", id stays "frontend-lead".
    parts = stem.split(maxsplit=1)
    if len(parts) == 2 and re.search(r"[A-Za-z0-9]", parts[1]) and not re.match(r"[A-Za-z0-9]", parts[0]):
        return parts[1]
    return stem

runtime_overrides = ws.get("role_runtimes", {})
if prompt_dir.exists():
    for path in sorted(prompt_dir.glob("*.md"), key=lambda p: role_id_from_stem(p.stem)):
        stem = path.stem
        role = role_id_from_stem(stem)
        if stem.startswith("_") or role in {"orchestrator", "hermes", "human"}:
            continue
        runtime = runtime_overrides.get(role, "claude")
        print("%s	%s	%s	%s" % (role, path, stem, runtime))
else:
    # Backward-compatible fallback for older workspaces with explicit JSON rosters.
    team_leads = ws.get("team_leads") or []
    for lead in team_leads:
        role = lead["id"] if isinstance(lead, dict) else str(lead)
        name = (lead.get("name") or lead.get("label") or role) if isinstance(lead, dict) else role
        prompt = (lead.get("prompt") or ".agent-cockpit/roles/%s.md" % role) if isinstance(lead, dict) else ".agent-cockpit/roles/%s.md" % role
        runtime = (lead.get("runtime") or "claude") if isinstance(lead, dict) else "claude"
        print("%s	%s	%s	%s" % (role, prompt, name, runtime))
PY
)

# Validate the program for every runtime this workspace uses, before creating any pane.
# (Replaces the old single Claude-only check; supports mixed claude/codex teams.)
declare -A _RT_SEEN=()
for rt in "$ORCH_RUNTIME" "${LEAD_RUNTIMES[@]:-}"; do
  [[ -z "$rt" || -n "${_RT_SEEN[$rt]:-}" ]] && continue
  _RT_SEEN[$rt]=1
  prog="$(runtime_program "$rt")"
  if [[ -z "$prog" ]]; then
    echo "unknown runtime '$rt' in role_runtimes — use 'claude' or 'codex'" >&2
    exit 1
  fi
  if ! command -v "$prog" >/dev/null 2>&1 && [[ ! -x "$prog" ]]; then
    echo "runtime '$rt' program not found/executable: $prog" >&2
    echo "  (for codex, set CODEX_BIN or reinstall; default is the app-bundled binary)" >&2
    exit 1
  fi
done

# Orchestrator pane: the fixed right column.
# Create at a generous virtual size so a tall left column of leads has room to split;
# tmux resizes to the client when one attaches. (A tiny default size makes split-window
# fail once there are several leads.)
ORCH=$(tmux new-session -d -P -F '#{pane_id}' -x "${COCKPIT_COLS:-260}" -y "${COCKPIT_ROWS:-72}" -s "$SESSION" -n roles -c "$WORKSPACE_ROOT" "$(agent_cmd orchestrator "$ORCH_PROMPT" "$ORCH_RUNTIME")")

# Lead panes laid out in COLUMNS of at most MAX_PER_COL, to the LEFT of the orchestrator.
# No column holds more than MAX_PER_COL panes; with more leads we add another column
# instead of a taller stack. Order is left->right then top->bottom, in workspace order.
# Only the orchestrator's right-column ownership is fixed; lead positions are incidental.
MAX_PER_COL="${COCKPIT_MAX_PER_COL:-3}"
N=${#LEAD_ROLES[@]}
LEAD_PANE=()        # LEAD_PANE[i] = pane id for lead i (parallel to LEAD_ROLES)
COL_HEADS=()        # head (top) pane of each lead column
NCOLS=0
if (( N > 0 )); then NCOLS=$(( (N + MAX_PER_COL - 1) / MAX_PER_COL )); fi

# 1) Column heads: each split is inserted just left of the orchestrator, so columns end
#    up ordered [col0][col1]...[orchestrator] left-to-right.
for (( c=0; c<NCOLS; c++ )); do
  idx=$(( c * MAX_PER_COL ))
  head=$(tmux split-window -P -F '#{pane_id}' -t "$ORCH" -h -b -c "$WORKSPACE_ROOT" \
           "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}" "${LEAD_RUNTIMES[$idx]}")") \
    || { echo "warn: no room for lead column $c — raise COCKPIT_COLS" >&2; continue; }
  LEAD_PANE[$idx]=$head
  COL_HEADS[$c]=$head
done

# 2) Stack the remaining leads (rows 1..MAX-1) under each column head.
for (( c=0; c<NCOLS; c++ )); do
  prev="${COL_HEADS[$c]:-}"
  [[ -z "$prev" ]] && continue
  for (( r=1; r<MAX_PER_COL; r++ )); do
    idx=$(( c * MAX_PER_COL + r ))
    if (( idx >= N )); then break; fi
    pane=$(tmux split-window -P -F '#{pane_id}' -t "$prev" -v -c "$WORKSPACE_ROOT" \
             "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}" "${LEAD_RUNTIMES[$idx]}")") \
      || { echo "warn: no room for lead '${LEAD_ROLES[$idx]}' — raise COCKPIT_ROWS" >&2; continue; }
    LEAD_PANE[$idx]=$pane
    prev=$pane
  done
done

# 3) Label every lead pane. @role is visible; @cockpit_role is the wake-target machine id.
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -z "$p" ]] && continue
  tmux select-pane -t "$p" -T "${LEAD_NAMES[$i]}"
  tmux set-option -pt "$p" @role "${LEAD_NAMES[$i]}"
  tmux set-option -pt "$p" @cockpit_role "${LEAD_ROLES[$i]}"
  tmux set-option -pt "$p" @cockpit_runtime "${LEAD_RUNTIMES[$i]}"
done

# Orchestrator labels (the one role tied to a position: it owns the right column).
tmux select-pane -t "$ORCH" -T "$ORCH_NAME"
tmux set-option -pt "$ORCH" @role "$ORCH_NAME · owns this column"
tmux set-option -pt "$ORCH" @cockpit_role "orchestrator"
tmux set-option -pt "$ORCH" @cockpit_runtime "$ORCH_RUNTIME"

# Even the column widths (orchestrator + NCOLS lead columns), then even rows per column.
WINDOW_WIDTH=$(tmux display-message -p -t "$SESSION:roles" '#{window_width}' 2>/dev/null || echo 200)
WIN_H=$(tmux display-message -p -t "$SESSION:roles" '#{window_height}' 2>/dev/null || echo 50)
if (( NCOLS > 0 )); then
  col_w=$(( WINDOW_WIDTH / (NCOLS + 1) ))
  for (( c=0; c<NCOLS; c++ )); do
    [[ -n "${COL_HEADS[$c]:-}" ]] && tmux resize-pane -t "${COL_HEADS[$c]}" -x "$col_w" >/dev/null 2>&1 || true
    rows=$(( N - c * MAX_PER_COL )); if (( rows > MAX_PER_COL )); then rows=$MAX_PER_COL; fi
    if (( rows > 1 )); then
      per=$(( WIN_H / rows ))
      for (( r=0; r<rows; r++ )); do
        p="${LEAD_PANE[$(( c * MAX_PER_COL + r ))]:-}"
        [[ -n "$p" ]] && tmux resize-pane -t "$p" -y "$per" >/dev/null 2>&1 || true
      done
    fi
  done
fi

tmux set-option -w -t "$SESSION:roles" pane-border-status top >/dev/null
tmux set-option -w -t "$SESSION:roles" pane-border-format ' #[bold,fg=cyan]#{@role} #[default]' >/dev/null

# Monitor window: logs/status are available but do not steal space from role panes.
tmux new-window -d -t "$SESSION" -n monitor -c "$ROOT" "$feed_cmd"
tmux split-window -t "$SESSION:monitor" -h -c "$ROOT" "$status_cmd"
tmux select-layout -t "$SESSION:monitor" even-horizontal >/dev/null
tmux select-pane -t "$SESSION:monitor.0" -T feed
tmux select-pane -t "$SESSION:monitor.1" -T status

# Default the user-facing window to the clean role grid.
tmux select-window -t "$SESSION:roles"
tmux select-pane -t "$ORCH"

sleep "${COCKPIT_CLAUDE_START_DELAY:-6}"
send_initial() {
  local pane_id="$1"
  local role="$2"
  local prompt_file="$3"
  local extra="${4:-}"
  # Send the prompt text and the Enter as SEPARATE send-keys calls. A combined
  # `send-keys "...text..." Enter` is unreliable right after Claude's TUI starts — the
  # Enter can land before the input is ready and the prompt sits unsubmitted. Two calls
  # (with a beat between) is what makes wake_pane reliable; mirror it here.
  tmux send-keys -t "$pane_id" -- "You are the $WORKSPACE workspace $role. You are running from repo/workspace root $WORKSPACE_ROOT. Read your charter $prompt_file and the shared protocol $SHARED_PROTOCOL. Projects and tasks live in LINEAR — use the Linear MCP as the system of record; there is no local task registry. Check your inbox now: $COCKPIT_BIN/dispatch inbox $role. Then wait — when someone dispatches you, this pane is woken automatically. Send messages with $COCKPIT_BIN/dispatch send --from $role --to <role> [--task LINEAR-ID] BODY.${extra:+ }$extra"
  sleep 0.4
  tmux send-keys -t "$pane_id" Enter
}

# Authoritative roster for the orchestrator: the exact leads THIS launch created, so it
# never falls back to a stale hardcoded list in its charter. Includes each lead's runtime.
ORCH_ROSTER=""
for (( i=0; i<N; i++ )); do
  [[ -z "${LEAD_PANE[$i]:-}" ]] && continue
  ORCH_ROSTER+="${ORCH_ROSTER:+, }${LEAD_ROLES[$i]} (${LEAD_RUNTIMES[$i]})"
done
ORCH_EXTRA="YOUR TEAM LEADS in this workspace are exactly these ${N} and they are ALL yours: ${ORCH_ROSTER}. Treat every one of them as your own lead — do not disown any as belonging to another workspace. Confirm the live roster any time with ./.agent-cockpit/bin/health (every *-lead pane is yours)."

send_initial "$ORCH" orchestrator "$ORCH_PROMPT" "$ORCH_EXTRA"
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -n "$p" ]] && send_initial "$p" "${LEAD_ROLES[$i]}" "${LEAD_PROMPTS[$i]}"
done

# Open visible iTerm window if available. If Automation permissions block this, tmux still runs.
if [[ "${COCKPIT_OPEN_ITERM:-1}" == "1" ]]; then
  osascript >/dev/null 2>&1 <<OSA || true
tell application "iTerm2"
  activate
  create window with default profile
  tell current session of current window
    write text "cd '$ROOT' && tmux attach -t '$SESSION'"
  end tell
end tell
OSA
fi

echo "started tmux session: $SESSION"
echo "main roles: cd $ROOT && tmux attach -t $SESSION:roles"
echo "monitor logs: Ctrl-b n, or tmux switch-client -t $SESSION:monitor"
printf '\nRoles panes:\n'
tmux list-panes -t "$SESSION:roles" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
printf '\nMonitor panes:\n'
tmux list-panes -t "$SESSION:monitor" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
