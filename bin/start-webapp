#!/usr/bin/env bash
set -euo pipefail

ROOT="/Users/seanchiu/Desktop/workspace-macbook"
SESSION="${COCKPIT_TMUX_SESSION:-macbook-webapp}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
KILL_EXISTING="${COCKPIT_KILL_EXISTING:-1}"

cd "$ROOT"

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is required" >&2
  exit 1
fi

if ! command -v "$CLAUDE_BIN" >/dev/null 2>&1; then
  echo "Claude Code command not found: $CLAUDE_BIN" >&2
  exit 1
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
  if [[ "$KILL_EXISTING" == "1" ]]; then
    tmux kill-session -t "$SESSION"
  else
    echo "session already exists: $SESSION" >&2
    exit 2
  fi
fi

agent_cmd() {
  local role="$1"
  local prompt_file="$2"
  cat <<EOF
cd "$ROOT"
export COCKPIT_TMUX_SESSION="$SESSION"
printf '\\033]2;%s\\033\\\\' "$role"
clear
printf 'MacBook webapp cockpit role: %s\\n' "$role"
printf 'Prompt file: %s\\n\\n' "$prompt_file"
printf 'Claude Code will start now. Initial instructions will be injected by tmux.\\n'
exec "$CLAUDE_BIN"
EOF
}

feed_cmd='cd /Users/seanchiu/Desktop/workspace-macbook; printf "\\033]2;feed\\033\\\\"; touch .agent-cockpit/shared/conversation.log; clear; echo "conversation feed (press Ctrl-b n/p to switch windows)"; tail -n 120 -f .agent-cockpit/shared/conversation.log'
status_cmd='cd /Users/seanchiu/Desktop/workspace-macbook; printf "\\033]2;status\\033\\\\"; while true; do clear; echo "cockpit status (updates every 5s)"; date; ./.agent-cockpit/bin/status || true; sleep 5; done'

# The ONLY fixed rule: the orchestrator owns the full-height RIGHT column. The team
# leads that fill the LEFT column are whatever THIS workspace declares — any number,
# any domain — read live from its workspace.json. Nothing here hardcodes specific leads;
# to change the team, edit the workspace's role_prompts/default_participants and relaunch.
WORKSPACE="${COCKPIT_WORKSPACE:-webapp}"
WS_JSON=".agent-cockpit/workspaces/$WORKSPACE/workspace.json"
if [[ ! -f "$WS_JSON" ]]; then
  echo "workspace config not found: $WS_JSON" >&2
  exit 1
fi

ORCH_PROMPT=$(python3 - "$WS_JSON" <<'PY'
import json, sys
ws = json.load(open(sys.argv[1]))
print(ws.get("role_prompts", {}).get("orchestrator", ".agent-cockpit/roles/orchestrator.md"))
PY
)
# Every role label carries an emoji (a workspace convention). Configured ones win; any
# lead without one gets a distinct fallback so the requirement always holds.
ORCH_EMOJI=$(python3 - "$WS_JSON" <<'PY'
import json, sys
ws = json.load(open(sys.argv[1]))
print(ws.get("role_emojis", {}).get("orchestrator", "🧭"))
PY
)
ORCH_RUNTIME=$(python3 - "$WS_JSON" <<'PY'
import json, sys
ws = json.load(open(sys.argv[1]))
print(ws.get("role_runtimes", {}).get("orchestrator", "claude"))
PY
)

# Build the lead list in declaration order, excluding orchestrator/hermes/human.
# Each line is: role <TAB> prompt_file <TAB> emoji
LEAD_ROLES=(); LEAD_PROMPTS=(); LEAD_EMOJIS=(); LEAD_RUNTIMES=()
while IFS=$'\t' read -r role pf emoji runtime; do
  [[ -z "$role" ]] && continue
  LEAD_ROLES+=("$role"); LEAD_PROMPTS+=("$pf"); LEAD_EMOJIS+=("$emoji")
  LEAD_RUNTIMES+=("${runtime:-claude}")
done < <(python3 - "$WS_JSON" <<'PY'
import json, sys
ws = json.load(open(sys.argv[1]))
prompts = ws.get("role_prompts", {})
emojis = ws.get("role_emojis", {})
runtimes = ws.get("role_runtimes", {})
pool = ["🧩", "📦", "🔭", "🛰", "🧪", "⚙", "📚", "🧰", "🔬", "🗂"]
order = list(prompts.keys()) + list(ws.get("default_participants", []))
seen = set()
fb = 0
for role in order:
    if role in ("hermes", "human", "orchestrator") or role in seen:
        continue
    seen.add(role)
    em = emojis.get(role)
    if not em:
        em = pool[fb % len(pool)]
        fb += 1
    rt = runtimes.get(role, "claude")
    print("%s\t%s\t%s\t%s" % (role, prompts.get(role, ".agent-cockpit/roles/%s.md" % role), em, rt))
PY
)

# Orchestrator pane: the fixed right column.
# Create at a generous virtual size so a tall left column of leads has room to split;
# tmux resizes to the client when one attaches. (A tiny default size makes split-window
# fail once there are several leads.)
ORCH=$(tmux new-session -d -P -F '#{pane_id}' -x "${COCKPIT_COLS:-260}" -y "${COCKPIT_ROWS:-72}" -s "$SESSION" -n roles -c "$ROOT" "$(agent_cmd orchestrator "$ORCH_PROMPT")")

# Lead panes laid out in COLUMNS of at most MAX_PER_COL, to the LEFT of the orchestrator.
# No column holds more than MAX_PER_COL panes; with more leads we add another column
# instead of a taller stack. Order is left->right then top->bottom, in workspace order.
# Only the orchestrator's right-column ownership is fixed; lead positions are incidental.
MAX_PER_COL="${COCKPIT_MAX_PER_COL:-3}"
N=${#LEAD_ROLES[@]}
LEAD_PANE=()        # LEAD_PANE[i] = pane id for lead i (parallel to LEAD_ROLES)
COL_HEADS=()        # head (top) pane of each lead column
NCOLS=0
if (( N > 0 )); then NCOLS=$(( (N + MAX_PER_COL - 1) / MAX_PER_COL )); fi

# 1) Column heads: each split is inserted just left of the orchestrator, so columns end
#    up ordered [col0][col1]...[orchestrator] left-to-right.
for (( c=0; c<NCOLS; c++ )); do
  idx=$(( c * MAX_PER_COL ))
  head=$(tmux split-window -P -F '#{pane_id}' -t "$ORCH" -h -b -c "$ROOT" \
           "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}")") \
    || { echo "warn: no room for lead column $c — raise COCKPIT_COLS" >&2; continue; }
  LEAD_PANE[$idx]=$head
  COL_HEADS[$c]=$head
done

# 2) Stack the remaining leads (rows 1..MAX-1) under each column head.
for (( c=0; c<NCOLS; c++ )); do
  prev="${COL_HEADS[$c]:-}"
  [[ -z "$prev" ]] && continue
  for (( r=1; r<MAX_PER_COL; r++ )); do
    idx=$(( c * MAX_PER_COL + r ))
    if (( idx >= N )); then break; fi
    pane=$(tmux split-window -P -F '#{pane_id}' -t "$prev" -v -c "$ROOT" \
             "$(agent_cmd "${LEAD_ROLES[$idx]}" "${LEAD_PROMPTS[$idx]}")") \
      || { echo "warn: no room for lead '${LEAD_ROLES[$idx]}' — raise COCKPIT_ROWS" >&2; continue; }
    LEAD_PANE[$idx]=$pane
    prev=$pane
  done
done

# 3) Label every lead pane (emoji + role; @cockpit_role is the wake-target machine id).
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -z "$p" ]] && continue
  tmux select-pane -t "$p" -T "${LEAD_EMOJIS[$i]} ${LEAD_ROLES[$i]}"
  tmux set-option -pt "$p" @role "${LEAD_EMOJIS[$i]} ${LEAD_ROLES[$i]}"
  tmux set-option -pt "$p" @cockpit_role "${LEAD_ROLES[$i]}"
done

# Orchestrator labels (the one role tied to a position: it owns the right column).
tmux select-pane -t "$ORCH" -T "$ORCH_EMOJI orchestrator"
tmux set-option -pt "$ORCH" @role "$ORCH_EMOJI orchestrator · owns this column"
tmux set-option -pt "$ORCH" @cockpit_role "orchestrator"

# Even the column widths (orchestrator + NCOLS lead columns), then even rows per column.
WINDOW_WIDTH=$(tmux display-message -p -t "$SESSION:roles" '#{window_width}' 2>/dev/null || echo 200)
WIN_H=$(tmux display-message -p -t "$SESSION:roles" '#{window_height}' 2>/dev/null || echo 50)
if (( NCOLS > 0 )); then
  col_w=$(( WINDOW_WIDTH / (NCOLS + 1) ))
  for (( c=0; c<NCOLS; c++ )); do
    [[ -n "${COL_HEADS[$c]:-}" ]] && tmux resize-pane -t "${COL_HEADS[$c]}" -x "$col_w" >/dev/null 2>&1 || true
    rows=$(( N - c * MAX_PER_COL )); if (( rows > MAX_PER_COL )); then rows=$MAX_PER_COL; fi
    if (( rows > 1 )); then
      per=$(( WIN_H / rows ))
      for (( r=0; r<rows; r++ )); do
        p="${LEAD_PANE[$(( c * MAX_PER_COL + r ))]:-}"
        [[ -n "$p" ]] && tmux resize-pane -t "$p" -y "$per" >/dev/null 2>&1 || true
      done
    fi
  done
fi

tmux set-option -w -t "$SESSION:roles" pane-border-status top >/dev/null
tmux set-option -w -t "$SESSION:roles" pane-border-format ' #[bold,fg=cyan]#{@role} #[default]' >/dev/null

# Monitor window: logs/status are available but do not steal space from role panes.
tmux new-window -d -t "$SESSION" -n monitor -c "$ROOT" "$feed_cmd"
tmux split-window -t "$SESSION:monitor" -h -c "$ROOT" "$status_cmd"
tmux select-layout -t "$SESSION:monitor" even-horizontal >/dev/null
tmux select-pane -t "$SESSION:monitor.0" -T feed
tmux select-pane -t "$SESSION:monitor.1" -T status

# Default the user-facing window to the clean role grid.
tmux select-window -t "$SESSION:roles"
tmux select-pane -t "$ORCH"

sleep "${COCKPIT_CLAUDE_START_DELAY:-6}"
send_initial() {
  local pane_id="$1"
  local role="$2"
  local prompt_file="$3"
  # Send the prompt text and the Enter as SEPARATE send-keys calls. A combined
  # `send-keys "...text..." Enter` is unreliable right after Claude's TUI starts — the
  # Enter can land before the input is ready and the prompt sits unsubmitted. Two calls
  # (with a beat between) is what makes wake_pane reliable; mirror it here.
  tmux send-keys -t "$pane_id" -- "You are the $WORKSPACE workspace $role. Read your charter $prompt_file and the shared protocol .agent-cockpit/roles/_PROTOCOL.md. Projects and tasks live in LINEAR — use the Linear MCP as the system of record; there is no local task registry. Check your inbox now: ./.agent-cockpit/bin/dispatch inbox $role. Then wait — when someone dispatches you, this pane is woken automatically. Send messages with ./.agent-cockpit/bin/dispatch send --from $role --to <role> [--task LINEAR-ID] BODY."
  sleep 0.4
  tmux send-keys -t "$pane_id" Enter
}

send_initial "$ORCH" orchestrator "$ORCH_PROMPT"
for (( i=0; i<N; i++ )); do
  p="${LEAD_PANE[$i]:-}"
  [[ -n "$p" ]] && send_initial "$p" "${LEAD_ROLES[$i]}" "${LEAD_PROMPTS[$i]}"
done

# Open visible iTerm window if available. If Automation permissions block this, tmux still runs.
if [[ "${COCKPIT_OPEN_ITERM:-1}" == "1" ]]; then
  osascript >/dev/null 2>&1 <<OSA || true
tell application "iTerm2"
  activate
  create window with default profile
  tell current session of current window
    write text "cd '$ROOT' && tmux attach -t '$SESSION'"
  end tell
end tell
OSA
fi

echo "started tmux session: $SESSION"
echo "main roles: cd $ROOT && tmux attach -t $SESSION:roles"
echo "monitor logs: Ctrl-b n, or tmux switch-client -t $SESSION:monitor"
printf '\nRoles panes:\n'
tmux list-panes -t "$SESSION:roles" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
printf '\nMonitor panes:\n'
tmux list-panes -t "$SESSION:monitor" -F '#{pane_index} #{pane_id} #{pane_title} #{pane_current_command} #{pane_current_path}'
