#!/usr/bin/env python3
"""Local dispatch CLI for the MacBook jumpcode.

The jumpcode owns only the *delivery* layer: visible panes, live wake, and a durable
dispatch log. Projects and tasks live in Linear (ADR 0003), not here. A single verb,
`dispatch`, both wakes the recipient's pane and appends to the append-only log under
.jumpcode/state/.
"""
from __future__ import annotations

import argparse
import fcntl
import json
import os
import re
import subprocess
import sys
import time
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional


EVENT_FILES = {
    "dispatch": "dispatches.jsonl",
}

DISPATCH_KINDS = ["request", "reply", "report-done", "report-blocked", "notice"]

ROLE_ID_RE = re.compile(r"^[a-z][a-z0-9-]*$")
KNOWN_RUNTIMES = {"claude", "codex"}
RESERVED_NON_ROLES = {"hermes", "human"}


class RoleDiscoveryError(ValueError):
    pass


def role_id_from_stem(stem: str) -> str:
    """Return canonical role id from a prompt filename stem.

    Supports display prefixes such as "🎨 frontend-lead" while keeping plain
    filenames like "frontend-lead" unchanged. The returned id is validated by
    discover_roles().
    """
    parts = stem.split(maxsplit=1)
    if len(parts) == 2 and re.search(r"[A-Za-z0-9]", parts[1]) and not re.match(r"[A-Za-z0-9]", parts[0]):
        return parts[1]
    return stem


def _workspace_json_candidates(home: Path, workspace: str) -> List[Path]:
    candidates = [home / "workspaces" / workspace / "workspace.json"]
    if home.name == ".jumpcode":
        candidates.append(home.parent / "workspaces" / workspace / "workspace.json")
    return candidates


def workspace_json_path(home: Path, workspace: str) -> Path:
    for candidate in _workspace_json_candidates(home, workspace):
        if candidate.exists():
            return candidate
    return _workspace_json_candidates(home, workspace)[0]


def load_workspace_settings(home: Path, workspace: str) -> Dict[str, Any]:
    path = workspace_json_path(home, workspace)
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise RoleDiscoveryError(f"invalid workspace settings JSON {path}: {e}") from e
    if not isinstance(data, dict):
        raise RoleDiscoveryError(f"workspace settings must be a JSON object: {path}")
    return data


def resolve_workspace_root(home: Path, workspace: str, settings: Dict[str, Any]) -> Path:
    default_base = home.parent if home.name == ".jumpcode" else home
    value = settings.get("workspace_root", str(default_base / "workspaces" / workspace))
    root = Path(str(value)).expanduser()
    if not root.is_absolute():
        root = default_base / root
    return root.resolve()


def _scan_role_source(source: Path, label: str) -> Dict[str, Dict[str, Any]]:
    roles: Dict[str, Dict[str, Any]] = {}
    if not source.exists():
        return roles
    if not source.is_dir():
        raise RoleDiscoveryError(f"role source is not a directory: {source}")
    for path in sorted(source.glob("*.md"), key=lambda p: p.name):
        stem = path.stem
        if stem.startswith("_"):
            continue
        rid = role_id_from_stem(stem)
        if not ROLE_ID_RE.match(rid):
            raise RoleDiscoveryError(f"invalid role id '{rid}' from {label} prompt {path.name}; expected {ROLE_ID_RE.pattern}")
        if rid in RESERVED_NON_ROLES:
            continue
        if rid in roles:
            raise RoleDiscoveryError(
                f"duplicate role id '{rid}' within {label} roles: {roles[rid]['prompt']} and {path}"
            )
        roles[rid] = {
            "id": rid,
            "display": stem,
            "prompt": str(path.resolve()),
            "runtime": "claude",
            "kind": "orchestrator" if rid == "orchestrator" else "lead",
            "_source": label,
        }
    return roles


def discover_roles(home: Path, workspace: str) -> Dict[str, Any]:
    settings = load_workspace_settings(home, workspace)
    workspace_root = resolve_workspace_root(home, workspace, settings)
    central_roles = (home / "roles").resolve()
    local_roles = (workspace_root / ".jumpcode" / "roles").resolve()

    central = _scan_role_source(central_roles, "central")
    local = _scan_role_source(local_roles, "repo-local")

    merged: Dict[str, Dict[str, Any]] = {rid: dict(role) for rid, role in central.items()}
    for rid, role in local.items():
        merged[rid] = dict(role)

    if "orchestrator" not in merged:
        raise RoleDiscoveryError("missing required role prompt for canonical id 'orchestrator'")

    local_protocol = local_roles / "_PROTOCOL.md"
    central_protocol = central_roles / "_PROTOCOL.md"
    if local_protocol.exists():
        protocol = local_protocol.resolve()
    elif central_protocol.exists():
        protocol = central_protocol.resolve()
    else:
        raise RoleDiscoveryError(f"missing shared protocol: expected {local_protocol} or {central_protocol}")

    runtime_overrides = settings.get("role_runtimes", {}) or {}
    if not isinstance(runtime_overrides, dict):
        raise RoleDiscoveryError("workspace setting 'role_runtimes' must be an object")
    for rid, runtime_value in runtime_overrides.items():
        if not ROLE_ID_RE.match(str(rid)):
            raise RoleDiscoveryError(f"invalid role_runtimes key '{rid}'; expected canonical role id")
        runtime = str(runtime_value)
        if runtime not in KNOWN_RUNTIMES:
            raise RoleDiscoveryError(f"unknown runtime '{runtime}' for role '{rid}' — use one of: {', '.join(sorted(KNOWN_RUNTIMES))}")
        if str(rid) not in merged:
            raise RoleDiscoveryError(f"role_runtimes references unknown role '{rid}'")

    roles_out: List[Dict[str, Any]] = []
    for rid in sorted(merged):
        role = dict(merged[rid])
        runtime = str(runtime_overrides.get(rid, role.get("runtime") or "claude"))
        if runtime not in KNOWN_RUNTIMES:
            raise RoleDiscoveryError(f"unknown runtime '{runtime}' for role '{rid}' — use one of: {', '.join(sorted(KNOWN_RUNTIMES))}")
        role["runtime"] = runtime
        role.pop("_source", None)
        roles_out.append(role)

    return {
        "workspace": workspace,
        "title": settings.get("title") or workspace,
        "workspace_root": str(workspace_root),
        "protocol": str(protocol),
        "roles": roles_out,
    }


def cmd_roles(args: argparse.Namespace, home: Path) -> int:
    if args.roles_cmd != "discover":
        return 2
    try:
        payload = discover_roles(home, args.workspace)
    except RoleDiscoveryError as e:
        print(f"roles discover: {e}", file=sys.stderr)
        return 1
    if args.json:
        print_json(payload)
    else:
        print(f"workspace: {payload['workspace']}")
        print(f"workspace_root: {payload['workspace_root']}")
        print(f"protocol: {payload['protocol']}")
        print("roles:")
        for role in payload["roles"]:
            print(f"  {role['id']:<16} {role['runtime']:<7} {role['kind']:<12} {role['display']}  {role['prompt']}")
    return 0


def resolve_pane(panes_text: str, role: str) -> Optional[str]:
    """Map a canonical role to a tmux pane id.

    `panes_text` is the output of `tmux list-panes -F '#{pane_id}\t#{@jumpcode_role}'`.
    Targets the machine-readable @jumpcode_role option, not the Claude-overwritten title.
    """
    for line in panes_text.splitlines():
        if "\t" not in line:
            continue
        pane_id, pane_role = line.split("\t", 1)
        if pane_role.strip() == role:
            return pane_id.strip()
    return None


def _injected_text_present(capture_text: str, text: str) -> bool:
    """True if `text` appears in a pane capture, tolerant of tmux line-wrapping.

    A narrow pane wraps the injected line across rows, so compare with whitespace
    stripped and match a distinctive leading slice rather than the whole string.
    """
    needle = re.sub(r"\s+", "", text)[:24]
    return bool(needle) and needle in re.sub(r"\s+", "", capture_text)


def wake_pane(session: str, role: str, text: str) -> bool:
    """Inject a nudge into the role's pane and submit it. Returns True only if VERIFIED.

    The live half of a dispatch: a Claude pane cannot poll its own inbox, so it sits idle
    until keystrokes are fed in. A naive send is unreliable — if the pane is mid-render
    (Claude's "recap"/spinner state) the keystrokes can be dropped silently. So we clear
    the input line, type the text, then CONFIRM it actually landed (capture-pane) before
    pressing Enter; if it didn't land we clear and retry once. Returning False here makes
    the dispatch's `woke` flag mean "verified delivered", not just "send-keys ran".
    """
    if not session:
        return False
    try:
        # -s = every pane in the SESSION, not just its current window — without it a
        # wake silently fails whenever the human last left the monitor window selected.
        out = subprocess.run(
            ["tmux", "list-panes", "-s", "-t", session, "-F", "#{pane_id}\t#{@jumpcode_role}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False
    pane = resolve_pane(out, role)
    if not pane:
        return False
    for _ in range(2):
        subprocess.run(["tmux", "send-keys", "-t", pane, "C-u"], check=False)  # clear stale input
        subprocess.run(["tmux", "send-keys", "-t", pane, "--", text], check=False)
        time.sleep(0.4)
        if _injected_text_present(_tmux_capture(pane), text):
            subprocess.run(["tmux", "send-keys", "-t", pane, "Enter"], check=False)
            return True
        subprocess.run(["tmux", "send-keys", "-t", pane, "C-u"], check=False)  # drop failed attempt
        time.sleep(0.3)
    return False


def resolve_session() -> str:
    """The tmux session whose panes we wake.

    Prefer an explicit JUMPCODE_TMUX_SESSION (set by external senders like Hermes). When
    unset but we are running INSIDE tmux (an agent in a pane dispatching a sibling),
    fall back to the current session so agent-to-agent wake works with no env wiring.
    """
    explicit = os.environ.get("JUMPCODE_TMUX_SESSION", "")
    if explicit:
        return explicit
    if os.environ.get("TMUX"):
        try:
            return subprocess.run(
                ["tmux", "display-message", "-p", "#{session_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
        except (subprocess.CalledProcessError, FileNotFoundError):
            return ""
    return ""


def scope_session(args: argparse.Namespace) -> Optional[str]:
    """The session a read/send command is scoped to — the collision fix's pivot.

    Dispatch identities are (session, role), not bare role names: three concurrent
    workspaces all have a 'backend-lead', and a shared unscoped log let any workspace's
    traffic land in every same-named lead's inbox. Explicit --session wins; --all-sessions
    (reads only) forces the unscoped global view; otherwise the caller's own tmux session
    applies. Returns None when unscoped (no session resolvable, or --all-sessions).
    """
    if getattr(args, "all_sessions", False):
        return None
    explicit = getattr(args, "session", None)
    if explicit:
        return explicit
    return resolve_session() or None


def scoped_dispatches(home: Path, args: argparse.Namespace) -> List[Dict[str, Any]]:
    """Dispatch events visible in the caller's scope.

    Scoped: only events tagged with the same session — untagged legacy events are
    EXCLUDED (they predate tagging and are cross-workspace soup; they remain visible in
    the unscoped/--all-sessions view). Unscoped: everything.
    """
    evs = events(home, "dispatch")
    scope = scope_session(args)
    if scope is None:
        return evs
    return [e for e in evs if e.get("session") == scope]


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def jumpcode_home() -> Path:
    override = os.environ.get("JUMPCODE_HOME")
    if override:
        return Path(override).expanduser().resolve()
    cwd = Path.cwd().resolve()
    if (cwd / "roles").is_dir() and (cwd / "bin" / "jumpcode").exists():
        return cwd
    existing = cwd / ".jumpcode"
    if existing.exists() or cwd.name != ".jumpcode":
        return existing
    return cwd


def ensure_dirs(home: Path) -> None:
    for rel in ["state", "shared", "bin", "roles"]:
        (home / rel).mkdir(parents=True, exist_ok=True)


@contextmanager
def _lock(home: Path):
    """Exclusive cross-process/thread lock.

    flock is per open file description, so a FRESH FD per acquisition is what makes this
    serialize threads in-process — do not hoist the open() to module scope, and never
    acquire this lock while already holding it (nesting deadlocks).
    """
    ensure_dirs(home)
    lock_path = home / "state" / ".lock"
    with lock_path.open("w") as lf:
        fcntl.flock(lf, fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf, fcntl.LOCK_UN)


def state_path(home: Path, kind: str) -> Path:
    return home / "state" / EVENT_FILES[kind]


def append_event(home: Path, kind: str, event: Dict[str, Any]) -> None:
    ensure_dirs(home)
    path = state_path(home, kind)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, sort_keys=True, ensure_ascii=False) + "\n")


def read_jsonl(path: Path) -> List[Dict[str, Any]]:
    if not path.exists():
        return []
    events_out: List[Dict[str, Any]] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.strip():
            events_out.append(json.loads(line))
    return events_out


def events(home: Path, kind: str) -> List[Dict[str, Any]]:
    return read_jsonl(state_path(home, kind))


def make_id(home: Path, prefix: str, kind: str = "") -> str:
    """Reserve a unique id of the form `prefix-YYYYMMDD-NNN`.

    Reservation is atomic: the per-(prefix,date) counter is read-incremented-persisted
    under `_lock`, so the id is claimed at mint time. This holds even when the caller's
    append happens in a separate, later call (no TOCTOU between mint and append).
    `kind` is accepted for backwards-compat but no longer used for numbering.
    """
    date = datetime.now(timezone.utc).strftime("%Y%m%d")
    key = f"{prefix}-{date}"
    with _lock(home):
        path = home / "state" / "counters.json"
        counters: Dict[str, int] = {}
        if path.exists():
            try:
                counters = json.loads(path.read_text(encoding="utf-8"))
            except (json.JSONDecodeError, ValueError):
                counters = {}
        count = int(counters.get(key, 0)) + 1
        counters[key] = count
        path.write_text(json.dumps(counters, sort_keys=True) + "\n", encoding="utf-8")
    return f"{key}-{count:03d}"


def print_json(payload: Any) -> None:
    print(json.dumps(payload, indent=None, sort_keys=True, ensure_ascii=False))


def append_conversation(home: Path, line: str) -> None:
    ensure_dirs(home)
    with (home / "shared" / "conversation.log").open("a", encoding="utf-8") as f:
        f.write(f"[{now_iso()}] {line}\n")


def _dispatch_one_liner(d: Dict[str, Any]) -> str:
    headline = d.get("subject") or (d.get("body", "") or "")[:80]
    return (
        f"{d.get('dispatch_id')} ({d.get('session') or 'unscoped'}) "
        f"{d.get('from')} -> {d.get('to')} "
        f"[{d.get('kind')}] task={d.get('task') or '-'} "
        f"project={d.get('project') or '-'}: {headline}"
    )


_REPORT_KINDS = ("report-done", "report-blocked")


def open_requests(dispatches: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    """Request dispatches that have no matching report — the open loops.

    A request is closed by a later report-done/report-blocked that either (a) sets
    `reply_to` to the request's id (precise linkage), or (b) — when reply_to is absent —
    comes from the request's recipient about the same task at/after the request time
    (heuristic fallback). Each report closes at most one request; requests are walked in
    order so concurrent same-task loops pair FIFO. Returns the still-open requests in
    chronological order.
    """
    reqs = [d for d in dispatches
            if d.get("type") == "dispatch.sent" and d.get("kind") == "request"]
    reports = [d for d in dispatches
               if d.get("type") == "dispatch.sent" and d.get("kind") in _REPORT_KINDS]
    req_ids = {r.get("dispatch_id") for r in reqs}
    matched: set = set()  # request ids closed
    used: set = set()     # report indices consumed

    # Phase 1 — precise links, resolved GLOBALLY before any fallback so a report
    # explicitly aimed (reply_to) at one request can never be stolen by another's
    # heuristic match. A report whose reply_to names no request closes nothing.
    for i, rep in enumerate(reports):
        rt = rep.get("reply_to")
        if rt and rt in req_ids and rt not in matched:
            matched.add(rt); used.add(i)

    # Phase 2 — heuristic fallback for the pre-linkage convention, over UNLINKED
    # reports only (a report with reply_to is precise-only). Requests walked in order
    # so concurrent same-task loops pair FIFO.
    for r in reqs:
        rid = r.get("dispatch_id")
        if rid in matched:
            continue
        for i, rep in enumerate(reports):
            if i in used or rep.get("reply_to"):
                continue
            if (rep.get("from") == r.get("to")
                    and rep.get("task") and rep.get("task") == r.get("task")
                    and (rep.get("created_at") or "") >= (r.get("created_at") or "")):
                used.add(i); matched.add(rid); break

    return [r for r in reqs if r.get("dispatch_id") not in matched]


def _age_str(iso_ts: Optional[str]) -> str:
    if not iso_ts:
        return "?"
    try:
        t = datetime.strptime(iso_ts, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
    except ValueError:
        return "?"
    secs = int((datetime.now(timezone.utc) - t).total_seconds())
    if secs < 90:
        return f"{secs}s"
    if secs < 5400:
        return f"{secs // 60}m"
    return f"{secs // 3600}h"


def pane_states_by_role(session: str) -> Dict[str, str]:
    """role -> working/waiting/idle for live panes in the session (empty if none)."""
    if not session:
        return {}
    try:
        text = subprocess.run(
            ["tmux", "list-panes", "-s", "-t", session, "-F",
             "#{pane_id}\t#{@jumpcode_role}\t#{@jumpcode_runtime}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return {}
    states: Dict[str, str] = {}
    for line in text.splitlines():
        parts = line.split("\t")
        if len(parts) < 2 or not parts[1].strip():
            continue
        pane_id, role = parts[0], parts[1].strip()
        runtime = parts[2].strip() if len(parts) >= 3 else ""
        states[role] = pane_state(_tmux_capture(pane_id), runtime or "claude")
    return states


def cmd_dispatch(args: argparse.Namespace, home: Path) -> int:
    if args.dispatch_cmd == "send":
        body = " ".join(args.body or []).strip()
        # The sender's workspace session is part of the dispatch's IDENTITY: role names
        # repeat across concurrent workspaces, so an untagged event is readable (and
        # actionable) by every same-named lead in every session — the hijack bug.
        session = args.session or resolve_session()
        event = {
            "type": "dispatch.sent",
            "dispatch_id": make_id(home, "dsp", "dispatch"),
            "session": session or None,
            "project": args.project,
            "task": args.task,
            "from": args.from_,
            "to": args.to,
            "kind": args.kind,
            "subject": args.subject or "",
            "body": body,
            "reply_to": args.reply_to,
            "created_at": now_iso(),
        }
        if not session:
            print("warning: no session resolvable — dispatch logged UNTAGGED (visible "
                  "only in --all-sessions reads) and cannot be delivered. Set "
                  "JUMPCODE_TMUX_SESSION or pass --session.", file=sys.stderr)
        # Resolve the delivery verdict BEFORE persisting, so the durable log records
        # whether the wake was *verified* (woke) — not merely that a send was attempted.
        # `None` = delivery not attempted (--no-wake / log-only). Wrapped so a wake
        # failure still yields woke=False and the dispatch is logged regardless.
        if args.no_wake:
            event["woke"] = None
        else:
            headline = event["subject"] or body[:80]
            try:
                event["woke"] = wake_pane(
                    session,
                    args.to,
                    f"[dispatch {event['dispatch_id']} from {event['from']}] {headline} "
                    f"— full text: ./.jumpcode/bin/dispatch show {event['dispatch_id']} "
                    f"(inbox: ./.jumpcode/bin/dispatch inbox {args.to})",
                )
            except Exception:
                event["woke"] = False
        append_event(home, "dispatch", event)
        append_conversation(
            home,
            f"[{session or 'unscoped'}] DISPATCH {event['kind']} {event['dispatch_id']} "
            f"{event['from']} -> {event['to']} "
            f"task={event.get('task') or '-'}: {event['subject'] or event['body'][:80]}",
        )
        print_json(event)
        return 0
    if args.dispatch_cmd == "inbox":
        msgs = [
            m for m in scoped_dispatches(home, args)
            if m.get("type") == "dispatch.sent" and m.get("to") == args.recipient
        ]
        if args.json:
            print_json(msgs)
        else:
            for m in msgs:
                print(_dispatch_one_liner(m))
        return 0
    if args.dispatch_cmd == "show":
        for m in events(home, "dispatch"):
            if m.get("dispatch_id") == args.dispatch_id:
                if args.json:
                    print_json(m)
                else:
                    print(json.dumps(m, indent=2, sort_keys=True, ensure_ascii=False))
                return 0
        print(f"Unknown dispatch: {args.dispatch_id}", file=sys.stderr)
        return 1
    if args.dispatch_cmd == "log":
        all_d = [m for m in scoped_dispatches(home, args) if m.get("type") == "dispatch.sent"]
        tail = all_d[-args.n:] if args.n else all_d
        for m in tail:
            print(f"[{m.get('created_at')}] {_dispatch_one_liner(m)}")
        return 0
    if args.dispatch_cmd == "status":
        dispatches = scoped_dispatches(home, args)
        opens = open_requests(dispatches)
        pstates = pane_states_by_role(scope_session(args) or resolve_session())
        rows = []
        for r in opens:
            to = r.get("to")
            rows.append({
                "dispatch_id": r.get("dispatch_id"),
                "to": to,
                "task": r.get("task"),
                "subject": r.get("subject") or (r.get("body", "") or "")[:60],
                "created_at": r.get("created_at"),
                "age": _age_str(r.get("created_at")),
                "pane_state": pstates.get(to, "absent"),
            })
        if args.json:
            print_json({"open": rows})
            return 0
        if not rows:
            print("no open loops — every request has a matching report.")
            return 0
        print(f"open loops: {len(rows)}  (requests with no matching report)")
        for row in rows:
            # idle/absent pane + open loop = likely silent finish or stall worth a nudge
            hint = {"working": "working", "waiting": "waiting-on-prompt",
                    "idle": "⚠ idle — likely silent finish, nudge",
                    "absent": "⚠ no pane"}.get(row["pane_state"], row["pane_state"])
            print(f"  {row['dispatch_id']} -> {row['to']:<14} task={row['task'] or '-':<8} "
                  f"age={row['age']:<5} pane={row['pane_state']:<8} {hint}")
        return 0
    return 2


# --- health check -----------------------------------------------------------

# Per-runtime status-line markers. Health reads a pane's @jumpcode_runtime to pick the
# right set. Claude and Codex overlap heavily (both surface "esc to interrupt" while
# working and numbered "1. Yes" approval prompts), but keep them separate so future
# divergence — or a third runtime — is a data edit, not a code change.
_RUNTIME_MARKERS = {
    "claude": {
        "busy": ("esc to interrupt",),
        "waiting": ("Do you want", "❯ 1.", "1. Yes", "Allow this"),
    },
    "codex": {
        # busy line confirmed live on 0.137.0-alpha.4 (2026-06-07): "• Working (Ns • esc to interrupt)".
        "busy": ("esc to interrupt",),
        # "Do you trust"/"1. Yes" confirmed live; "Allow command" is an unverified guess
        # at Codex's exec-approval prompt (health is best-effort, so a miss only mislabels idle/waiting).
        "waiting": ("Do you trust", "1. Yes", "› 1.", "Allow command"),
    },
}


def pane_state(capture_text: str, runtime: str = "claude") -> str:
    """Classify a captured agent pane as 'working' | 'waiting' | 'idle' for its runtime.

    An unknown/empty runtime falls back to the claude marker set (the markers overlap, so
    this is safe and keeps health useful even if @jumpcode_runtime was never set).

    The real "working" signal is the spinner line ('… esc to interrupt'). Claude's
    auto-mode footer ('⏵⏵ auto mode on … · <hint>') rotates a hint that sometimes reads
    '· esc to interrupt' even when idle — so that footer line is excluded before scanning,
    or every auto-mode pane would read as working. (Live-confirmed 2026-06-07, CC 2.1.168.)
    """
    markers = _RUNTIME_MARKERS.get(runtime) or _RUNTIME_MARKERS["claude"]
    scan = "\n".join(ln for ln in capture_text.splitlines() if "auto mode on" not in ln)
    if any(m in scan for m in markers["busy"]):
        return "working"
    if any(m in scan for m in markers["waiting"]):
        return "waiting"
    return "idle"


_SUBAGENT_RE = re.compile(r"^subagent:(start|end)\b[:\s]*(.*)$", re.IGNORECASE)


def active_subagents(dispatches: List[Dict[str, Any]]) -> Dict[str, List[str]]:
    """Per-role active subagents, from the leads-self-report convention.

    A lead announces subagent lifecycle with a notice dispatch whose subject is
    'subagent:start <name>' / 'subagent:end <name>'. Active = started minus ended,
    grouped by the announcing role. Returns only roles with >=1 active subagent.
    """
    active: Dict[str, List[str]] = {}
    for d in dispatches:
        if d.get("type") != "dispatch.sent" or d.get("kind") != "notice":
            continue
        m = _SUBAGENT_RE.match((d.get("subject") or "").strip())
        if not m:
            continue
        event = m.group(1).lower()
        name = m.group(2).strip() or "(unnamed)"
        role = d.get("from") or "(unknown)"
        names = active.setdefault(role, [])
        if event == "start":
            names.append(name)
        elif name in names:
            names.remove(name)
        elif names:
            names.pop()
    return {role: names for role, names in active.items() if names}


def last_seen_by_role(dispatches: List[Dict[str, Any]]) -> Dict[str, Dict[str, Optional[str]]]:
    """Per-role last activity, split by DIRECTION.

    'spoke' = the role last appeared as a dispatch's `from` (it acted / replied);
    'addressed' = it last appeared as `to` (it was woken). A lead woken but silent has
    a fresh `addressed` and a stale/None `spoke` — the "asked, still no answer" signal a
    single merged last_seen hides. Dispatches are chronological, so the last write wins.
    """
    out: Dict[str, Dict[str, Optional[str]]] = {}
    for d in dispatches:
        if d.get("type") != "dispatch.sent":
            continue
        ts = d.get("created_at")
        frm, to = d.get("from"), d.get("to")
        if frm:
            out.setdefault(frm, {"spoke": None, "addressed": None})["spoke"] = ts
        if to:
            out.setdefault(to, {"spoke": None, "addressed": None})["addressed"] = ts
    return out


def _tmux_capture(pane_id: str) -> str:
    try:
        return subprocess.run(
            ["tmux", "capture-pane", "-p", "-t", pane_id],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def _tmux_capture_scroll(pane_id: str, lines: int) -> str:
    """Capture the last `lines` rows of a pane, including scrollback (-S -N)."""
    try:
        return subprocess.run(
            ["tmux", "capture-pane", "-p", "-t", pane_id, "-S", f"-{lines}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def cmd_peek(args: argparse.Namespace, home: Path) -> int:
    """Read-only window into a role's pane — the orchestrator's eyes (monitoring design).

    Resolves the role via the same @jumpcode_role/session machinery as wake, then prints
    `capture-pane` scrollback so the caller can judge mid-work vs. idle vs. error vs. dead
    shell. Never sends keys: to *act*, use `dispatch send` (which wakes). Fails with a
    clear message — never a traceback — when the session or pane isn't found.
    """
    session = resolve_session()
    if not session:
        print("peek: no jumpcode session — set JUMPCODE_TMUX_SESSION or run inside the "
              "workspace tmux session.", file=sys.stderr)
        return 1
    try:
        panes_text = subprocess.run(
            ["tmux", "list-panes", "-s", "-t", session, "-F", "#{pane_id}\t#{@jumpcode_role}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        print(f"peek: tmux session '{session}' not found (workspace not running?).",
              file=sys.stderr)
        return 1
    pane = resolve_pane(panes_text, args.role)
    if not pane:
        print(f"peek: no pane for role '{args.role}' in session '{session}'.",
              file=sys.stderr)
        return 1
    out = _tmux_capture_scroll(pane, args.lines)
    sys.stdout.write(out)
    if out and not out.endswith("\n"):
        sys.stdout.write("\n")
    return 0


def session_visibility() -> List[Dict[str, Any]]:
    """Every tmux session paired with its attached-client count — the reliable
    'is anyone looking at this?' layer. A session that exists in `tmux ls` but
    has 0 clients is running headless: agents alive, no window showing them
    (e.g. after a kill+relaunch closed its iTerm tab). A dead `[exited]` window
    is NOT a client, so it correctly does not count as visible."""
    try:
        sessions = [s for s in subprocess.run(
            ["tmux", "ls", "-F", "#{session_name}"],
            capture_output=True, text=True, check=True,
        ).stdout.splitlines() if s.strip()]
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []
    out: List[Dict[str, Any]] = []
    for s in sessions:
        try:
            n = len([c for c in subprocess.run(
                ["tmux", "list-clients", "-t", s, "-F", "#{client_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.splitlines() if c.strip()])
        except (subprocess.CalledProcessError, FileNotFoundError):
            n = 0
        out.append({"session": s, "clients": n, "visible": n > 0})
    return out


def cmd_health(args: argparse.Namespace, home: Path) -> int:
    session = getattr(args, "session", None) or resolve_session()
    # Dispatch-derived fields (subagents, last spoke/addressed, silent) are scoped to
    # this session: same-named roles in other workspaces are different identities.
    dispatches = scoped_dispatches(home, args)
    subs = active_subagents(dispatches)

    seen = last_seen_by_role(dispatches)

    def _seen_fields(role: str) -> Dict[str, Any]:
        s = seen.get(role, {})
        spoke, addressed = s.get("spoke"), s.get("addressed")
        # "silent" = woken more recently than it last spoke (or never spoke): asked,
        # no answer yet. ISO-8601 'Z' timestamps compare correctly as strings.
        silent = addressed is not None and (spoke is None or addressed > spoke)
        return {
            "last_spoke": spoke,
            "last_addressed": addressed,
            "last_seen": max([t for t in (spoke, addressed) if t], default=None),
            "silent": silent,
        }

    panes_text = ""
    if session:
        try:
            panes_text = subprocess.run(
                ["tmux", "list-panes", "-s", "-t", session, "-F",
                 "#{pane_id}\t#{@jumpcode_role}\t#{pane_current_command}\t#{pane_dead}\t#{@jumpcode_runtime}"],
                capture_output=True, text=True, check=True,
            ).stdout
        except (subprocess.CalledProcessError, FileNotFoundError):
            panes_text = ""

    agents: List[Dict[str, Any]] = []
    seen_roles = set()
    for line in panes_text.splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        pane_id, role, cmd, dead = parts[0], parts[1].strip(), parts[2], parts[3]
        runtime = parts[4].strip() if len(parts) >= 5 else ""
        if not role:
            continue
        seen_roles.add(role)
        alive = dead != "1"
        state = "stopped" if not alive else pane_state(_tmux_capture(pane_id), runtime or "claude")
        agents.append({
            "role": role, "pane": pane_id, "alive": alive, "command": cmd,
            "runtime": runtime or "claude",
            "state": state, "subagents": subs.get(role, []),
            **_seen_fields(role),
        })

    # Roles that have appeared in the dispatch log but have no live pane right now.
    for role in sorted(r for r in seen if r not in seen_roles
                       and r not in ("hermes", "human")):
        agents.append({
            "role": role, "pane": None, "alive": False, "command": None,
            "runtime": None,
            "state": "absent", "subagents": subs.get(role, []),
            **_seen_fields(role),
        })

    clients = 0
    if session:
        try:
            clients = len([c for c in subprocess.run(
                ["tmux", "list-clients", "-t", session, "-F", "#{client_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.splitlines() if c.strip()])
        except (subprocess.CalledProcessError, FileNotFoundError):
            clients = 0

    visibility = session_visibility()
    result = {"session": session or None, "attached_clients": clients,
              "agents": agents, "visibility": visibility}
    if args.json:
        print_json(result)
        return 0

    print(f"session: {session or '(none)'}   attached clients: {clients}")
    # Loud, actionable flag: this session's agents are running but no window shows
    # them. Silent "attached clients: 0" is exactly what let an invisible session hide.
    if session and clients == 0 and any(a["alive"] for a in agents):
        print(f"  ⚠ NO WINDOW ATTACHED — running headless. Reattach with:")
        print(f"      tmux attach -t {session}:roles")
    if not agents:
        print("  no jumpcode panes found "
              "(set JUMPCODE_TMUX_SESSION or run inside the session)")
    for a in agents:
        dot = "●" if a["alive"] else "○"
        sub = ("  subagents=" + ", ".join(a["subagents"])) if a["subagents"] else ""
        silent = "  ⚠ woken,no-reply" if a.get("silent") else ""
        print(f"  {dot} {a['role']:<16} {(a.get('runtime') or '-'):<7} {a['state']:<8} "
              f"spoke={a.get('last_spoke') or '-'} addressed={a.get('last_addressed') or '-'}"
              f"{silent}{sub}")

    # Fleet visibility: every tmux session and whether a window is showing it. An
    # invisible session (0 clients) is healthy but no human can see it — surfaced
    # here so it can never hide, even when health is run against another session.
    if visibility:
        print("visibility (all tmux sessions):")
        for v in visibility:
            mark = "●" if v["visible"] else "○"
            tag = f"{v['clients']} window(s)" if v["visible"] else "NO WINDOW — tmux attach -t %s:roles" % v["session"]
            print(f"  {mark} {v['session']:<22} {tag}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="jumpcode", description="Local dispatch CLI (Linear owns projects/tasks)"
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    dispatch = sub.add_parser("dispatch", help="send/inspect dispatches")
    dsub = dispatch.add_subparsers(dest="dispatch_cmd", required=True)

    def add_scope_flags(p: argparse.ArgumentParser, readonly: bool = True) -> None:
        # Dispatch identities are (session, role): same-named roles in concurrent
        # workspaces are different agents. Default scope = the caller's own session.
        p.add_argument("--session", help="scope to this tmux session "
                       "(default: $JUMPCODE_TMUX_SESSION / current tmux session)")
        if readonly:
            p.add_argument("--all-sessions", action="store_true",
                           help="unscoped global view (includes untagged legacy events)")

    ds = dsub.add_parser("send", help="deliver a dispatch (live wake + durable log)")
    ds.add_argument("--from", dest="from_", required=True)
    ds.add_argument("--to", required=True)
    ds.add_argument("--project")
    ds.add_argument("--task")
    ds.add_argument("--subject", default="")
    ds.add_argument("--kind", default="request", choices=DISPATCH_KINDS)
    ds.add_argument("--reply-to", dest="reply_to")
    ds.add_argument("--no-wake", action="store_true", help="log only; do not inject into a pane")
    add_scope_flags(ds, readonly=False)
    ds.add_argument("body", nargs="*")

    di = dsub.add_parser("inbox", help="dispatches addressed to a recipient (this session's)")
    di.add_argument("recipient")
    di.add_argument("--json", action="store_true")
    add_scope_flags(di)

    dsh = dsub.add_parser("show", help="show one dispatch by id")
    dsh.add_argument("dispatch_id")
    dsh.add_argument("--json", action="store_true")

    dl = dsub.add_parser("log", help="human-readable dispatch feed (this session's)")
    dl.add_argument("n", nargs="?", type=int, default=40)
    add_scope_flags(dl)

    dst = dsub.add_parser("status", help="open loops: requests with no matching report (this session's)")
    dst.add_argument("--json", action="store_true")
    add_scope_flags(dst)

    roles = sub.add_parser("roles", help="discover/validate workspace roles")
    rsub = roles.add_subparsers(dest="roles_cmd", required=True)
    rd = rsub.add_parser("discover", help="discover validated roles for a workspace")
    rd.add_argument("--workspace", required=True)
    rd.add_argument("--json", action="store_true")

    health = sub.add_parser("health", help="per-role liveness / busy / subagent snapshot (this session's)")
    health.add_argument("--json", action="store_true")
    health.add_argument("--session", help="scope to this tmux session "
                        "(default: $JUMPCODE_TMUX_SESSION / current tmux session)")
    health.add_argument("--all-sessions", action="store_true",
                        help="dispatch-derived fields unscoped (panes still need a session)")

    peek = sub.add_parser("peek", help="read-only view of a role's pane (never sends keys)")
    peek.add_argument("role")
    peek.add_argument("lines", nargs="?", type=int, default=50)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    home = jumpcode_home()
    ensure_dirs(home)
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd == "dispatch":
        return cmd_dispatch(args, home)
    if args.cmd == "roles":
        return cmd_roles(args, home)
    if args.cmd == "health":
        return cmd_health(args, home)
    if args.cmd == "peek":
        return cmd_peek(args, home)
    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
