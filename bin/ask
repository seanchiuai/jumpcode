#!/usr/bin/env bash
set -euo pipefail
if [[ $# -lt 2 ]]; then
  echo "usage: ask <agent> <message...>" >&2
  exit 2
fi
TO="$1"; shift
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FROM="${COCKPIT_FROM:-hermes}"
TASK_ARG=()
if [[ -n "${COCKPIT_TASK:-}" ]]; then TASK_ARG=(--task "$COCKPIT_TASK"); fi
python3 "$DIR/cockpit" mail send --from "$FROM" --to "$TO" "${TASK_ARG[@]}" "$@"
# If a tmux session has a pane named like the recipient, also inject a visible message.
SESSION="${COCKPIT_TMUX_SESSION:-}"
if [[ -n "$SESSION" ]] && command -v tmux >/dev/null 2>&1; then
  target="$(tmux list-panes -t "$SESSION" -F '#{pane_index}:#{pane_title}' 2>/dev/null | awk -F: -v role="$TO" '$2 == role {print $1; exit}')"
  if [[ -n "$target" ]]; then
    tmux send-keys -t "$SESSION.$target" "COCKPIT MESSAGE from $FROM to $TO: $*" Enter
  fi
fi
