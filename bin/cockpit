#!/usr/bin/env python3
"""Local dispatch CLI for the MacBook agent cockpit.

The cockpit owns only the *delivery* layer: visible panes, live wake, and a durable
dispatch log. Projects and tasks live in Linear (ADR 0003), not here. A single verb,
`dispatch`, both wakes the recipient's pane and appends to the append-only log under
.agent-cockpit/state/.
"""
from __future__ import annotations

import argparse
import fcntl
import json
import os
import re
import subprocess
import sys
import time
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional


EVENT_FILES = {
    "dispatch": "dispatches.jsonl",
}

DISPATCH_KINDS = ["request", "reply", "report-done", "report-blocked", "notice"]


def resolve_pane(panes_text: str, role: str) -> Optional[str]:
    """Map a canonical role to a tmux pane id.

    `panes_text` is the output of `tmux list-panes -F '#{pane_id}\t#{@cockpit_role}'`.
    Targets the machine-readable @cockpit_role option, not the Claude-overwritten title.
    """
    for line in panes_text.splitlines():
        if "\t" not in line:
            continue
        pane_id, pane_role = line.split("\t", 1)
        if pane_role.strip() == role:
            return pane_id.strip()
    return None


def _injected_text_present(capture_text: str, text: str) -> bool:
    """True if `text` appears in a pane capture, tolerant of tmux line-wrapping.

    A narrow pane wraps the injected line across rows, so compare with whitespace
    stripped and match a distinctive leading slice rather than the whole string.
    """
    needle = re.sub(r"\s+", "", text)[:24]
    return bool(needle) and needle in re.sub(r"\s+", "", capture_text)


def wake_pane(session: str, role: str, text: str) -> bool:
    """Inject a nudge into the role's pane and submit it. Returns True only if VERIFIED.

    The live half of a dispatch: a Claude pane cannot poll its own inbox, so it sits idle
    until keystrokes are fed in. A naive send is unreliable — if the pane is mid-render
    (Claude's "recap"/spinner state) the keystrokes can be dropped silently. So we clear
    the input line, type the text, then CONFIRM it actually landed (capture-pane) before
    pressing Enter; if it didn't land we clear and retry once. Returning False here makes
    the dispatch's `woke` flag mean "verified delivered", not just "send-keys ran".
    """
    if not session:
        return False
    try:
        out = subprocess.run(
            ["tmux", "list-panes", "-t", session, "-F", "#{pane_id}\t#{@cockpit_role}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False
    pane = resolve_pane(out, role)
    if not pane:
        return False
    for _ in range(2):
        subprocess.run(["tmux", "send-keys", "-t", pane, "C-u"], check=False)  # clear stale input
        subprocess.run(["tmux", "send-keys", "-t", pane, "--", text], check=False)
        time.sleep(0.4)
        if _injected_text_present(_tmux_capture(pane), text):
            subprocess.run(["tmux", "send-keys", "-t", pane, "Enter"], check=False)
            return True
        subprocess.run(["tmux", "send-keys", "-t", pane, "C-u"], check=False)  # drop failed attempt
        time.sleep(0.3)
    return False


def resolve_session() -> str:
    """The tmux session whose panes we wake.

    Prefer an explicit COCKPIT_TMUX_SESSION (set by external senders like Hermes). When
    unset but we are running INSIDE tmux (an agent in a pane dispatching a sibling),
    fall back to the current session so agent-to-agent wake works with no env wiring.
    """
    explicit = os.environ.get("COCKPIT_TMUX_SESSION", "")
    if explicit:
        return explicit
    if os.environ.get("TMUX"):
        try:
            return subprocess.run(
                ["tmux", "display-message", "-p", "#{session_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
        except (subprocess.CalledProcessError, FileNotFoundError):
            return ""
    return ""


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def cockpit_home() -> Path:
    override = os.environ.get("COCKPIT_HOME")
    if override:
        return Path(override).expanduser().resolve()
    cwd = Path.cwd().resolve()
    existing = cwd / ".agent-cockpit"
    if existing.exists() or cwd.name != ".agent-cockpit":
        return existing
    return cwd


def ensure_dirs(home: Path) -> None:
    for rel in ["state", "shared", "bin", "roles"]:
        (home / rel).mkdir(parents=True, exist_ok=True)


@contextmanager
def _lock(home: Path):
    """Exclusive cross-process/thread lock.

    flock is per open file description, so a FRESH FD per acquisition is what makes this
    serialize threads in-process — do not hoist the open() to module scope, and never
    acquire this lock while already holding it (nesting deadlocks).
    """
    ensure_dirs(home)
    lock_path = home / "state" / ".lock"
    with lock_path.open("w") as lf:
        fcntl.flock(lf, fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf, fcntl.LOCK_UN)


def state_path(home: Path, kind: str) -> Path:
    return home / "state" / EVENT_FILES[kind]


def append_event(home: Path, kind: str, event: Dict[str, Any]) -> None:
    ensure_dirs(home)
    path = state_path(home, kind)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, sort_keys=True, ensure_ascii=False) + "\n")


def read_jsonl(path: Path) -> List[Dict[str, Any]]:
    if not path.exists():
        return []
    events_out: List[Dict[str, Any]] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.strip():
            events_out.append(json.loads(line))
    return events_out


def events(home: Path, kind: str) -> List[Dict[str, Any]]:
    return read_jsonl(state_path(home, kind))


def make_id(home: Path, prefix: str, kind: str = "") -> str:
    """Reserve a unique id of the form `prefix-YYYYMMDD-NNN`.

    Reservation is atomic: the per-(prefix,date) counter is read-incremented-persisted
    under `_lock`, so the id is claimed at mint time. This holds even when the caller's
    append happens in a separate, later call (no TOCTOU between mint and append).
    `kind` is accepted for backwards-compat but no longer used for numbering.
    """
    date = datetime.now(timezone.utc).strftime("%Y%m%d")
    key = f"{prefix}-{date}"
    with _lock(home):
        path = home / "state" / "counters.json"
        counters: Dict[str, int] = {}
        if path.exists():
            try:
                counters = json.loads(path.read_text(encoding="utf-8"))
            except (json.JSONDecodeError, ValueError):
                counters = {}
        count = int(counters.get(key, 0)) + 1
        counters[key] = count
        path.write_text(json.dumps(counters, sort_keys=True) + "\n", encoding="utf-8")
    return f"{key}-{count:03d}"


def print_json(payload: Any) -> None:
    print(json.dumps(payload, indent=None, sort_keys=True, ensure_ascii=False))


def append_conversation(home: Path, line: str) -> None:
    ensure_dirs(home)
    with (home / "shared" / "conversation.log").open("a", encoding="utf-8") as f:
        f.write(f"[{now_iso()}] {line}\n")


def _dispatch_one_liner(d: Dict[str, Any]) -> str:
    headline = d.get("subject") or (d.get("body", "") or "")[:80]
    return (
        f"{d.get('dispatch_id')} {d.get('from')} -> {d.get('to')} "
        f"[{d.get('kind')}] task={d.get('task') or '-'} "
        f"project={d.get('project') or '-'}: {headline}"
    )


def cmd_dispatch(args: argparse.Namespace, home: Path) -> int:
    if args.dispatch_cmd == "send":
        body = " ".join(args.body or []).strip()
        event = {
            "type": "dispatch.sent",
            "dispatch_id": make_id(home, "dsp", "dispatch"),
            "project": args.project,
            "task": args.task,
            "from": args.from_,
            "to": args.to,
            "kind": args.kind,
            "subject": args.subject or "",
            "body": body,
            "reply_to": args.reply_to,
            "created_at": now_iso(),
        }
        # Resolve the delivery verdict BEFORE persisting, so the durable log records
        # whether the wake was *verified* (woke) — not merely that a send was attempted.
        # `None` = delivery not attempted (--no-wake / log-only). Wrapped so a wake
        # failure still yields woke=False and the dispatch is logged regardless.
        if args.no_wake:
            event["woke"] = None
        else:
            session = resolve_session()
            headline = event["subject"] or body[:80]
            try:
                event["woke"] = wake_pane(
                    session,
                    args.to,
                    f"[dispatch {event['dispatch_id']} from {event['from']}] {headline} "
                    f"— full text: ./.agent-cockpit/bin/dispatch show {event['dispatch_id']} "
                    f"(inbox: ./.agent-cockpit/bin/dispatch inbox {args.to})",
                )
            except Exception:
                event["woke"] = False
        append_event(home, "dispatch", event)
        append_conversation(
            home,
            f"DISPATCH {event['kind']} {event['dispatch_id']} {event['from']} -> {event['to']} "
            f"task={event.get('task') or '-'}: {event['subject'] or event['body'][:80]}",
        )
        print_json(event)
        return 0
    if args.dispatch_cmd == "inbox":
        msgs = [
            m for m in events(home, "dispatch")
            if m.get("type") == "dispatch.sent" and m.get("to") == args.recipient
        ]
        if args.json:
            print_json(msgs)
        else:
            for m in msgs:
                print(_dispatch_one_liner(m))
        return 0
    if args.dispatch_cmd == "show":
        for m in events(home, "dispatch"):
            if m.get("dispatch_id") == args.dispatch_id:
                if args.json:
                    print_json(m)
                else:
                    print(json.dumps(m, indent=2, sort_keys=True, ensure_ascii=False))
                return 0
        print(f"Unknown dispatch: {args.dispatch_id}", file=sys.stderr)
        return 1
    if args.dispatch_cmd == "log":
        all_d = [m for m in events(home, "dispatch") if m.get("type") == "dispatch.sent"]
        tail = all_d[-args.n:] if args.n else all_d
        for m in tail:
            print(f"[{m.get('created_at')}] {_dispatch_one_liner(m)}")
        return 0
    return 2


# --- health check -----------------------------------------------------------

# Per-runtime status-line markers. Health reads a pane's @cockpit_runtime to pick the
# right set. Claude and Codex overlap heavily (both surface "esc to interrupt" while
# working and numbered "1. Yes" approval prompts), but keep them separate so future
# divergence — or a third runtime — is a data edit, not a code change.
_RUNTIME_MARKERS = {
    "claude": {
        "busy": ("esc to interrupt",),
        "waiting": ("Do you want", "❯ 1.", "1. Yes", "Allow this"),
    },
    "codex": {
        # busy line confirmed live on 0.137.0-alpha.4 (2026-06-07): "• Working (Ns • esc to interrupt)".
        "busy": ("esc to interrupt",),
        # "Do you trust"/"1. Yes" confirmed live; "Allow command" is an unverified guess
        # at Codex's exec-approval prompt (health is best-effort, so a miss only mislabels idle/waiting).
        "waiting": ("Do you trust", "1. Yes", "› 1.", "Allow command"),
    },
}


def pane_state(capture_text: str, runtime: str = "claude") -> str:
    """Classify a captured agent pane as 'working' | 'waiting' | 'idle' for its runtime.

    An unknown/empty runtime falls back to the claude marker set (the markers overlap, so
    this is safe and keeps health useful even if @cockpit_runtime was never set).
    """
    markers = _RUNTIME_MARKERS.get(runtime) or _RUNTIME_MARKERS["claude"]
    if any(m in capture_text for m in markers["busy"]):
        return "working"
    if any(m in capture_text for m in markers["waiting"]):
        return "waiting"
    return "idle"


_SUBAGENT_RE = re.compile(r"^subagent:(start|end)\b[:\s]*(.*)$", re.IGNORECASE)


def active_subagents(dispatches: List[Dict[str, Any]]) -> Dict[str, List[str]]:
    """Per-role active subagents, from the leads-self-report convention.

    A lead announces subagent lifecycle with a notice dispatch whose subject is
    'subagent:start <name>' / 'subagent:end <name>'. Active = started minus ended,
    grouped by the announcing role. Returns only roles with >=1 active subagent.
    """
    active: Dict[str, List[str]] = {}
    for d in dispatches:
        if d.get("type") != "dispatch.sent" or d.get("kind") != "notice":
            continue
        m = _SUBAGENT_RE.match((d.get("subject") or "").strip())
        if not m:
            continue
        event = m.group(1).lower()
        name = m.group(2).strip() or "(unnamed)"
        role = d.get("from") or "(unknown)"
        names = active.setdefault(role, [])
        if event == "start":
            names.append(name)
        elif name in names:
            names.remove(name)
        elif names:
            names.pop()
    return {role: names for role, names in active.items() if names}


def _tmux_capture(pane_id: str) -> str:
    try:
        return subprocess.run(
            ["tmux", "capture-pane", "-p", "-t", pane_id],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def cmd_health(args: argparse.Namespace, home: Path) -> int:
    session = resolve_session()
    dispatches = events(home, "dispatch")
    subs = active_subagents(dispatches)

    last_seen: Dict[str, str] = {}
    for d in dispatches:
        if d.get("type") != "dispatch.sent":
            continue
        ts = d.get("created_at")
        for role in (d.get("from"), d.get("to")):
            if role:
                last_seen[role] = ts

    panes_text = ""
    if session:
        try:
            panes_text = subprocess.run(
                ["tmux", "list-panes", "-t", session, "-F",
                 "#{pane_id}\t#{@cockpit_role}\t#{pane_current_command}\t#{pane_dead}\t#{@cockpit_runtime}"],
                capture_output=True, text=True, check=True,
            ).stdout
        except (subprocess.CalledProcessError, FileNotFoundError):
            panes_text = ""

    agents: List[Dict[str, Any]] = []
    seen_roles = set()
    for line in panes_text.splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        pane_id, role, cmd, dead = parts[0], parts[1].strip(), parts[2], parts[3]
        runtime = parts[4].strip() if len(parts) >= 5 else ""
        if not role:
            continue
        seen_roles.add(role)
        alive = dead != "1"
        state = "stopped" if not alive else pane_state(_tmux_capture(pane_id), runtime or "claude")
        agents.append({
            "role": role, "pane": pane_id, "alive": alive, "command": cmd,
            "runtime": runtime or "claude",
            "state": state, "subagents": subs.get(role, []),
            "last_seen": last_seen.get(role),
        })

    # Roles that have appeared in the dispatch log but have no live pane right now.
    for role in sorted(r for r in last_seen if r not in seen_roles
                       and r not in ("hermes", "human")):
        agents.append({
            "role": role, "pane": None, "alive": False, "command": None,
            "runtime": None,
            "state": "absent", "subagents": subs.get(role, []),
            "last_seen": last_seen.get(role),
        })

    clients = 0
    if session:
        try:
            clients = len([c for c in subprocess.run(
                ["tmux", "list-clients", "-t", session, "-F", "#{client_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.splitlines() if c.strip()])
        except (subprocess.CalledProcessError, FileNotFoundError):
            clients = 0

    result = {"session": session or None, "attached_clients": clients, "agents": agents}
    if args.json:
        print_json(result)
        return 0

    print(f"session: {session or '(none)'}   attached clients: {clients}")
    if not agents:
        print("  no cockpit panes found "
              "(set COCKPIT_TMUX_SESSION or run inside the session)")
    for a in agents:
        dot = "●" if a["alive"] else "○"
        sub = ("  subagents=" + ", ".join(a["subagents"])) if a["subagents"] else ""
        print(f"  {dot} {a['role']:<16} {(a.get('runtime') or '-'):<7} {a['state']:<8} "
              f"last_seen={a['last_seen'] or '-'}{sub}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="cockpit", description="Local dispatch CLI (Linear owns projects/tasks)"
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    dispatch = sub.add_parser("dispatch", help="send/inspect dispatches")
    dsub = dispatch.add_subparsers(dest="dispatch_cmd", required=True)

    ds = dsub.add_parser("send", help="deliver a dispatch (live wake + durable log)")
    ds.add_argument("--from", dest="from_", required=True)
    ds.add_argument("--to", required=True)
    ds.add_argument("--project")
    ds.add_argument("--task")
    ds.add_argument("--subject", default="")
    ds.add_argument("--kind", default="request", choices=DISPATCH_KINDS)
    ds.add_argument("--reply-to", dest="reply_to")
    ds.add_argument("--no-wake", action="store_true", help="log only; do not inject into a pane")
    ds.add_argument("body", nargs="*")

    di = dsub.add_parser("inbox", help="dispatches addressed to a recipient")
    di.add_argument("recipient")
    di.add_argument("--json", action="store_true")

    dsh = dsub.add_parser("show", help="show one dispatch by id")
    dsh.add_argument("dispatch_id")
    dsh.add_argument("--json", action="store_true")

    dl = dsub.add_parser("log", help="human-readable dispatch feed")
    dl.add_argument("n", nargs="?", type=int, default=40)

    health = sub.add_parser("health", help="per-role liveness / busy / subagent snapshot")
    health.add_argument("--json", action="store_true")

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    home = cockpit_home()
    ensure_dirs(home)
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd == "dispatch":
        return cmd_dispatch(args, home)
    if args.cmd == "health":
        return cmd_health(args, home)
    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
