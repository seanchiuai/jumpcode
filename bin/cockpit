#!/usr/bin/env python3
"""Local dispatch CLI for the MacBook agent cockpit.

The cockpit owns only the *delivery* layer: visible panes, live wake, and a durable
dispatch log. Projects and tasks live in Linear (ADR 0003), not here. A single verb,
`dispatch`, both wakes the recipient's pane and appends to the append-only log under
.agent-cockpit/state/.
"""
from __future__ import annotations

import argparse
import fcntl
import json
import os
import subprocess
import sys
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional


EVENT_FILES = {
    "dispatch": "dispatches.jsonl",
}

DISPATCH_KINDS = ["request", "reply", "report-done", "report-blocked", "notice"]


def resolve_pane(panes_text: str, role: str) -> Optional[str]:
    """Map a canonical role to a tmux pane id.

    `panes_text` is the output of `tmux list-panes -F '#{pane_id}\t#{@cockpit_role}'`.
    Targets the machine-readable @cockpit_role option, not the Claude-overwritten title.
    """
    for line in panes_text.splitlines():
        if "\t" not in line:
            continue
        pane_id, pane_role = line.split("\t", 1)
        if pane_role.strip() == role:
            return pane_id.strip()
    return None


def wake_pane(session: str, role: str, text: str) -> bool:
    """Inject a one-line nudge into the role's pane. Returns True if a pane was found+sent.

    The live half of a dispatch: a Claude pane cannot poll its own inbox, so it sits idle
    until keystrokes are fed in. We send the text, then a separate Enter so it submits.
    """
    if not session:
        return False
    try:
        out = subprocess.run(
            ["tmux", "list-panes", "-t", session, "-F", "#{pane_id}\t#{@cockpit_role}"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False
    pane = resolve_pane(out, role)
    if not pane:
        return False
    subprocess.run(["tmux", "send-keys", "-t", pane, "--", text], check=False)
    subprocess.run(["tmux", "send-keys", "-t", pane, "Enter"], check=False)
    return True


def resolve_session() -> str:
    """The tmux session whose panes we wake.

    Prefer an explicit COCKPIT_TMUX_SESSION (set by external senders like Hermes). When
    unset but we are running INSIDE tmux (an agent in a pane dispatching a sibling),
    fall back to the current session so agent-to-agent wake works with no env wiring.
    """
    explicit = os.environ.get("COCKPIT_TMUX_SESSION", "")
    if explicit:
        return explicit
    if os.environ.get("TMUX"):
        try:
            return subprocess.run(
                ["tmux", "display-message", "-p", "#{session_name}"],
                capture_output=True, text=True, check=True,
            ).stdout.strip()
        except (subprocess.CalledProcessError, FileNotFoundError):
            return ""
    return ""


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def cockpit_home() -> Path:
    override = os.environ.get("COCKPIT_HOME")
    if override:
        return Path(override).expanduser().resolve()
    cwd = Path.cwd().resolve()
    existing = cwd / ".agent-cockpit"
    if existing.exists() or cwd.name != ".agent-cockpit":
        return existing
    return cwd


def ensure_dirs(home: Path) -> None:
    for rel in ["state", "shared", "bin", "roles"]:
        (home / rel).mkdir(parents=True, exist_ok=True)


@contextmanager
def _lock(home: Path):
    """Exclusive cross-process/thread lock.

    flock is per open file description, so a FRESH FD per acquisition is what makes this
    serialize threads in-process — do not hoist the open() to module scope, and never
    acquire this lock while already holding it (nesting deadlocks).
    """
    ensure_dirs(home)
    lock_path = home / "state" / ".lock"
    with lock_path.open("w") as lf:
        fcntl.flock(lf, fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf, fcntl.LOCK_UN)


def state_path(home: Path, kind: str) -> Path:
    return home / "state" / EVENT_FILES[kind]


def append_event(home: Path, kind: str, event: Dict[str, Any]) -> None:
    ensure_dirs(home)
    path = state_path(home, kind)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(event, sort_keys=True, ensure_ascii=False) + "\n")


def read_jsonl(path: Path) -> List[Dict[str, Any]]:
    if not path.exists():
        return []
    events_out: List[Dict[str, Any]] = []
    for line in path.read_text(encoding="utf-8").splitlines():
        if line.strip():
            events_out.append(json.loads(line))
    return events_out


def events(home: Path, kind: str) -> List[Dict[str, Any]]:
    return read_jsonl(state_path(home, kind))


def make_id(home: Path, prefix: str, kind: str = "") -> str:
    """Reserve a unique id of the form `prefix-YYYYMMDD-NNN`.

    Reservation is atomic: the per-(prefix,date) counter is read-incremented-persisted
    under `_lock`, so the id is claimed at mint time. This holds even when the caller's
    append happens in a separate, later call (no TOCTOU between mint and append).
    `kind` is accepted for backwards-compat but no longer used for numbering.
    """
    date = datetime.now(timezone.utc).strftime("%Y%m%d")
    key = f"{prefix}-{date}"
    with _lock(home):
        path = home / "state" / "counters.json"
        counters: Dict[str, int] = {}
        if path.exists():
            try:
                counters = json.loads(path.read_text(encoding="utf-8"))
            except (json.JSONDecodeError, ValueError):
                counters = {}
        count = int(counters.get(key, 0)) + 1
        counters[key] = count
        path.write_text(json.dumps(counters, sort_keys=True) + "\n", encoding="utf-8")
    return f"{key}-{count:03d}"


def print_json(payload: Any) -> None:
    print(json.dumps(payload, indent=None, sort_keys=True, ensure_ascii=False))


def append_conversation(home: Path, line: str) -> None:
    ensure_dirs(home)
    with (home / "shared" / "conversation.log").open("a", encoding="utf-8") as f:
        f.write(f"[{now_iso()}] {line}\n")


def _dispatch_one_liner(d: Dict[str, Any]) -> str:
    headline = d.get("subject") or (d.get("body", "") or "")[:80]
    return (
        f"{d.get('dispatch_id')} {d.get('from')} -> {d.get('to')} "
        f"[{d.get('kind')}] task={d.get('task') or '-'} "
        f"project={d.get('project') or '-'}: {headline}"
    )


def cmd_dispatch(args: argparse.Namespace, home: Path) -> int:
    if args.dispatch_cmd == "send":
        body = " ".join(args.body or []).strip()
        event = {
            "type": "dispatch.sent",
            "dispatch_id": make_id(home, "dsp", "dispatch"),
            "project": args.project,
            "task": args.task,
            "from": args.from_,
            "to": args.to,
            "kind": args.kind,
            "subject": args.subject or "",
            "body": body,
            "reply_to": args.reply_to,
            "created_at": now_iso(),
        }
        append_event(home, "dispatch", event)
        append_conversation(
            home,
            f"DISPATCH {event['kind']} {event['dispatch_id']} {event['from']} -> {event['to']} "
            f"task={event.get('task') or '-'}: {event['subject'] or event['body'][:80]}",
        )
        if not args.no_wake:
            session = resolve_session()
            headline = event["subject"] or body[:80]
            woke = wake_pane(
                session,
                args.to,
                f"[dispatch {event['dispatch_id']} from {event['from']}] {headline} "
                f"— read it: ./.agent-cockpit/bin/dispatch inbox {args.to}",
            )
            event["woke"] = woke
        print_json(event)
        return 0
    if args.dispatch_cmd == "inbox":
        msgs = [
            m for m in events(home, "dispatch")
            if m.get("type") == "dispatch.sent" and m.get("to") == args.recipient
        ]
        if args.json:
            print_json(msgs)
        else:
            for m in msgs:
                print(_dispatch_one_liner(m))
        return 0
    if args.dispatch_cmd == "show":
        for m in events(home, "dispatch"):
            if m.get("dispatch_id") == args.dispatch_id:
                if args.json:
                    print_json(m)
                else:
                    print(json.dumps(m, indent=2, sort_keys=True, ensure_ascii=False))
                return 0
        print(f"Unknown dispatch: {args.dispatch_id}", file=sys.stderr)
        return 1
    if args.dispatch_cmd == "log":
        all_d = [m for m in events(home, "dispatch") if m.get("type") == "dispatch.sent"]
        tail = all_d[-args.n:] if args.n else all_d
        for m in tail:
            print(f"[{m.get('created_at')}] {_dispatch_one_liner(m)}")
        return 0
    return 2


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="cockpit", description="Local dispatch CLI (Linear owns projects/tasks)"
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    dispatch = sub.add_parser("dispatch", help="send/inspect dispatches")
    dsub = dispatch.add_subparsers(dest="dispatch_cmd", required=True)

    ds = dsub.add_parser("send", help="deliver a dispatch (live wake + durable log)")
    ds.add_argument("--from", dest="from_", required=True)
    ds.add_argument("--to", required=True)
    ds.add_argument("--project")
    ds.add_argument("--task")
    ds.add_argument("--subject", default="")
    ds.add_argument("--kind", default="request", choices=DISPATCH_KINDS)
    ds.add_argument("--reply-to", dest="reply_to")
    ds.add_argument("--no-wake", action="store_true", help="log only; do not inject into a pane")
    ds.add_argument("body", nargs="*")

    di = dsub.add_parser("inbox", help="dispatches addressed to a recipient")
    di.add_argument("recipient")
    di.add_argument("--json", action="store_true")

    dsh = dsub.add_parser("show", help="show one dispatch by id")
    dsh.add_argument("dispatch_id")
    dsh.add_argument("--json", action="store_true")

    dl = dsub.add_parser("log", help="human-readable dispatch feed")
    dl.add_argument("n", nargs="?", type=int, default=40)

    return parser


def main(argv: Optional[List[str]] = None) -> int:
    home = cockpit_home()
    ensure_dirs(home)
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.cmd == "dispatch":
        return cmd_dispatch(args, home)
    parser.error("unknown command")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
